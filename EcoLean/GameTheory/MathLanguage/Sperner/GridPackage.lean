import EcoLean.GameTheory.MathLanguage.Sperner.FreudenthalDatum

namespace EcoLean
namespace SpernerFreudenthal

open scoped BigOperators

namespace BarycentricFreudenthal

/-
The raw `BaryFreudenthalDatum` incidence route is postponed. For Brouwer we
instead use geometric small simplices as the cell type, avoiding overcounting
of oriented/proof-field representatives.
-/

abbrev GridSmallSimplex (d N : ℕ) :=
  {S : Finset (SimplexGrid d N) //
    ∃ D : BaryFreudenthalDatum d N, D.toSimplex.vertices = S}

namespace BaryFreudenthalDatum

noncomputable def toGridSmallSimplex {d N : ℕ}
    (D : BaryFreudenthalDatum d N) :
    GridSmallSimplex d N :=
  ⟨D.toSimplex.vertices, ⟨D, rfl⟩⟩

end BaryFreudenthalDatum

namespace GridSmallSimplex

def vertices {d N : ℕ} (C : GridSmallSimplex d N) :
    Finset (SimplexGrid d N) :=
  C.1

end GridSmallSimplex

noncomputable instance instGridSmallSimplexDecidableEq (d N : ℕ) :
    DecidableEq (GridSmallSimplex d N) :=
  Classical.decEq _

/-- All geometric small simplices generated by barycentric Freudenthal data. -/
noncomputable def allGridSmallSimplices (d N : ℕ) :
    Finset (GridSmallSimplex d N) :=
  (BaryFreudenthalDatum.all d N).image
    BaryFreudenthalDatum.toGridSmallSimplex

theorem mem_allGridSmallSimplices {d N : ℕ}
    (C : GridSmallSimplex d N) :
    C ∈ allGridSmallSimplices d N := by
  classical
  rcases C.2 with ⟨D, hD⟩
  refine Finset.mem_image.mpr ⟨D, BaryFreudenthalDatum.mem_all D, ?_⟩
  apply Subtype.ext
  exact hD

noncomputable instance instGridSmallSimplexFintype (d N : ℕ) :
    Fintype (GridSmallSimplex d N) :=
  ⟨allGridSmallSimplices d N, mem_allGridSmallSimplices⟩

def FullyLabelledGridSmallSimplex {d N : ℕ}
    (L : SimplexGrid d N → Fin (d + 1))
    (C : GridSmallSimplex d N) : Prop :=
  EcoLean.Sperner.FullyLabeled L C.vertices

def GridIsSperner {d N : ℕ}
    (L : SimplexGrid d N → Fin (d + 1)) : Prop :=
  ∀ x : SimplexGrid d N, L x ∈ x.support

namespace SimplexGrid

/-- The boundary face opposite `missing`, i.e. where that barycentric coordinate vanishes. -/
def onBoundaryFace {d N : ℕ}
    (missing : Fin (d + 1))
    (x : SimplexGrid d N) : Prop :=
  x.1 missing = 0

end SimplexGrid

/-- Coordinate indices remaining after deleting `missing`. -/
abbrev BoundaryIndex (d : ℕ) (missing : Fin (d + 1)) :=
  {i : Fin (d + 1) // i ≠ missing}

namespace BoundaryIndex

theorem card {d : ℕ}
    (missing : Fin (d + 1)) :
    Fintype.card (BoundaryIndex d missing) = d := by
  classical
  change Fintype.card {i : Fin (d + 1) // i ≠ missing} = d
  rw [Fintype.card_subtype]
  have hset :
      ({i : Fin (d + 1) | i ≠ missing} : Finset (Fin (d + 1))) =
        Finset.univ.erase missing := by
    ext i
    simp
  rw [hset, Finset.card_erase_of_mem (Finset.mem_univ missing)]
  simp [Fintype.card_fin]

/-- An arbitrary finite equivalence from the remaining coordinates to `Fin d`. -/
noncomputable def equivFin {d : ℕ}
    (missing : Fin (d + 1)) :
    BoundaryIndex d missing ≃ Fin d :=
  Fintype.equivFinOfCardEq (BoundaryIndex.card missing)

/-- The inverse equivalence, often more convenient for defining coordinates. -/
noncomputable def finEquiv {d : ℕ}
    (missing : Fin (d + 1)) :
    Fin d ≃ BoundaryIndex d missing :=
  (BoundaryIndex.equivFin missing).symm

theorem sum_eq_sum_erase {d : ℕ}
    (missing : Fin (d + 1))
    (f : Fin (d + 1) → ℕ) :
    (∑ i : BoundaryIndex d missing, f i.1) =
      (Finset.univ.erase missing).sum f := by
  classical
  have hsum := Finset.sum_subtype_eq_sum_filter
    (s := (Finset.univ : Finset (Fin (d + 1))))
    (f := f)
    (p := fun i : Fin (d + 1) => i ≠ missing)
  rw [Finset.subtype_univ] at hsum
  have hfilter :
      ((Finset.univ : Finset (Fin (d + 1))).filter
          fun i : Fin (d + 1) => i ≠ missing)
        =
      (Finset.univ.erase missing) := by
    ext i
    simp
  simpa [BoundaryIndex, hfilter] using hsum

end BoundaryIndex

namespace SimplexGrid

/--
Restrict a point on a successor-dimensional boundary face to the lower grid.

This is stated for `SimplexGrid (d + 1) N`, whose coordinates are `Fin (d + 2)`;
deleting one coordinate leaves `Fin (d + 1)`, the coordinate type of
`SimplexGrid d N`.
-/
noncomputable def restrictBoundarySucc {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (x : SimplexGrid (d + 1) N)
    (hx : SimplexGrid.onBoundaryFace missing x) :
    SimplexGrid d N := by
  classical
  let e := BoundaryIndex.finEquiv missing
  refine ⟨fun j : Fin (d + 1) => x.1 ((e j).1), ?_⟩
  have hcomp :
      (∑ j : Fin (d + 1), x.1 ((e j).1)) =
        ∑ i : BoundaryIndex (d + 1) missing, x.1 i.1 := by
    simpa [e] using
      (Equiv.sum_comp (BoundaryIndex.finEquiv missing)
        (fun i : BoundaryIndex (d + 1) missing => x.1 i.1))
  have herase :
      (∑ i : BoundaryIndex (d + 1) missing, x.1 i.1) =
        (Finset.univ.erase missing).sum x.1 :=
    BoundaryIndex.sum_eq_sum_erase missing x.1
  have hsplit :
      (Finset.univ.erase missing).sum x.1 + x.1 missing =
        ∑ i : Fin ((d + 1) + 1), x.1 i :=
    Finset.sum_erase_add (Finset.univ : Finset (Fin ((d + 1) + 1)))
      x.1 (Finset.mem_univ missing)
  calc
    (∑ j : Fin (d + 1), x.1 ((e j).1))
        = ∑ i : BoundaryIndex (d + 1) missing, x.1 i.1 := hcomp
    _ = (Finset.univ.erase missing).sum x.1 := herase
    _ = N := by
      have hxzero : x.1 missing = 0 := hx
      have hxsum := x.2
      omega

/-- Extend a lower-dimensional grid point by inserting zero at `missing`. -/
noncomputable def extendBoundarySucc {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (y : SimplexGrid d N) :
    SimplexGrid (d + 1) N := by
  classical
  let e := BoundaryIndex.equivFin missing
  let coord : Fin ((d + 1) + 1) → ℕ := fun i =>
    if h : i = missing then 0 else y.1 (e ⟨i, h⟩)
  refine ⟨coord, ?_⟩
  have hmissing : coord missing = 0 := by
    simp [coord]
  have hsumErase :
      (Finset.univ.erase missing).sum coord + coord missing =
        ∑ i : Fin ((d + 1) + 1), coord i :=
    Finset.sum_erase_add (Finset.univ : Finset (Fin ((d + 1) + 1)))
      coord (Finset.mem_univ missing)
  have hboundary :
      (∑ i : BoundaryIndex (d + 1) missing, coord i.1) =
        (Finset.univ.erase missing).sum coord :=
    BoundaryIndex.sum_eq_sum_erase missing coord
  have hcomp :
      (∑ i : BoundaryIndex (d + 1) missing, coord i.1) =
        ∑ j : Fin (d + 1), y.1 j := by
    have hcoord :
        (∀ i : BoundaryIndex (d + 1) missing,
          coord i.1 = y.1 (e i)) := by
      intro i
      simp [coord, i.2]
    calc
      (∑ i : BoundaryIndex (d + 1) missing, coord i.1)
          = ∑ i : BoundaryIndex (d + 1) missing, y.1 (e i) := by
            apply Finset.sum_congr rfl
            intro i _hi
            exact hcoord i
      _ = ∑ j : Fin (d + 1), y.1 j := by
        have h := Equiv.sum_comp (BoundaryIndex.equivFin missing)
          (fun j : Fin (d + 1) => y.1 j)
        simpa [e] using h
  calc
    (∑ i : Fin ((d + 1) + 1), coord i)
        = (Finset.univ.erase missing).sum coord + coord missing :=
          hsumErase.symm
    _ = (Finset.univ.erase missing).sum coord := by
      rw [hmissing, add_zero]
    _ = ∑ i : BoundaryIndex (d + 1) missing, coord i.1 := hboundary.symm
    _ = ∑ j : Fin (d + 1), y.1 j := hcomp
    _ = N := y.2

theorem extendBoundarySucc_onBoundaryFace {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (y : SimplexGrid d N) :
    SimplexGrid.onBoundaryFace missing
      (SimplexGrid.extendBoundarySucc missing y) := by
  classical
  simp [SimplexGrid.onBoundaryFace, SimplexGrid.extendBoundarySucc]

theorem extendBoundarySucc_coord_of_ne {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (y : SimplexGrid d N)
    {i : Fin ((d + 1) + 1)}
    (hi : i ≠ missing) :
    (SimplexGrid.extendBoundarySucc missing y).1 i =
      y.1 (BoundaryIndex.equivFin missing ⟨i, hi⟩) := by
  classical
  simp [SimplexGrid.extendBoundarySucc, hi]

theorem restrict_extendBoundarySucc {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (y : SimplexGrid d N) :
    SimplexGrid.restrictBoundarySucc missing
      (SimplexGrid.extendBoundarySucc missing y)
      (SimplexGrid.extendBoundarySucc_onBoundaryFace missing y)
      = y := by
  classical
  ext j
  have hne : ((BoundaryIndex.finEquiv missing) j).1 ≠ missing :=
    ((BoundaryIndex.finEquiv missing) j).2
  have hinv :
      BoundaryIndex.equivFin missing ((BoundaryIndex.finEquiv missing) j) = j :=
    Equiv.apply_symm_apply (BoundaryIndex.equivFin missing) j
  simp [SimplexGrid.restrictBoundarySucc, SimplexGrid.extendBoundarySucc,
    hne, hinv]

theorem extend_restrictBoundarySucc {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (x : SimplexGrid (d + 1) N)
    (hx : SimplexGrid.onBoundaryFace missing x) :
    SimplexGrid.extendBoundarySucc missing
      (SimplexGrid.restrictBoundarySucc missing x hx)
      = x := by
  classical
  ext i
  have hxzero : x.1 missing = 0 := hx
  by_cases hi : i = missing
  · subst hi
    simp [SimplexGrid.extendBoundarySucc, hxzero]
  · have hinv :
        (BoundaryIndex.finEquiv missing)
            ((BoundaryIndex.equivFin missing) ⟨i, hi⟩) = ⟨i, hi⟩ :=
      Equiv.symm_apply_apply (BoundaryIndex.equivFin missing) ⟨i, hi⟩
    have hval :
        ((BoundaryIndex.finEquiv missing)
            ((BoundaryIndex.equivFin missing) ⟨i, hi⟩)).1 = i :=
      congrArg Subtype.val hinv
    simp [SimplexGrid.extendBoundarySucc, SimplexGrid.restrictBoundarySucc,
      hi, hval]

/-- The boundary face of a successor-dimensional grid is the lower-dimensional grid. -/
noncomputable def boundaryFaceEquivSucc {d N : ℕ}
    (missing : Fin ((d + 1) + 1)) :
    {x : SimplexGrid (d + 1) N // SimplexGrid.onBoundaryFace missing x}
      ≃
    SimplexGrid d N :=
  { toFun := fun x => SimplexGrid.restrictBoundarySucc missing x.1 x.2
    invFun := fun y =>
      ⟨SimplexGrid.extendBoundarySucc missing y,
        SimplexGrid.extendBoundarySucc_onBoundaryFace missing y⟩
    left_inv := by
      intro x
      apply Subtype.ext
      exact SimplexGrid.extend_restrictBoundarySucc missing x.1 x.2
    right_inv := by
      intro y
      exact SimplexGrid.restrict_extendBoundarySucc missing y }

end SimplexGrid

/-- The grid vertices on the boundary face opposite `missing`. -/
noncomputable def boundaryGridVertices {d N : ℕ}
    (missing : Fin (d + 1)) :
    Finset (SimplexGrid d N) := by
  classical
  exact Finset.univ.filter fun x =>
    SimplexGrid.onBoundaryFace missing x

/-- The real barycentric realisation of a grid point. -/
noncomputable def realiseSimplexGrid {d N : ℕ} [NeZero N]
    (x : SimplexGrid d N) : Fin (d + 1) → ℝ :=
  fun i => (x.1 i : ℝ) / (N : ℝ)

theorem realiseSimplexGrid_nonneg {d N : ℕ} [NeZero N]
    (x : SimplexGrid d N) (i : Fin (d + 1)) :
    0 ≤ realiseSimplexGrid x i := by
  have hNpos : (0 : ℝ) < (N : ℝ) := by
    have hNnat : 0 < N := Nat.pos_of_ne_zero (NeZero.ne N)
    exact_mod_cast hNnat
  exact div_nonneg (by positivity) hNpos.le

theorem realiseSimplexGrid_sum_eq_one {d N : ℕ} [NeZero N]
    (x : SimplexGrid d N) :
    (∑ i, realiseSimplexGrid x i) = 1 := by
  classical
  have hN : (N : ℝ) ≠ 0 := by
    exact_mod_cast (NeZero.ne N)
  have hsum : (∑ i : Fin (d + 1), (x.1 i : ℝ)) = (N : ℝ) := by
    exact_mod_cast x.2
  calc
    (∑ i, realiseSimplexGrid x i)
        = (∑ i : Fin (d + 1), (x.1 i : ℝ)) / (N : ℝ) := by
          simpa [realiseSimplexGrid] using
            (Finset.sum_div (Finset.univ : Finset (Fin (d + 1)))
              (fun i : Fin (d + 1) => (x.1 i : ℝ)) (N : ℝ)).symm
    _ = (N : ℝ) / (N : ℝ) := by rw [hsum]
    _ = 1 := div_self hN

/--
Coordinatewise sup-distance bound for barycentric realisations, stated as an
upper-bound predicate to avoid importing metric-space infrastructure here.
-/
def BarySupDistLe {d : ℕ}
    (x y : Fin (d + 1) → ℝ) (ε : ℝ) : Prop :=
  ∀ i : Fin (d + 1), |x i - y i| ≤ ε

namespace GridSmallSimplex

/-- A small simplex has mesh at most `ε` if all realised vertex pairs are that close. -/
def MeshLe {d N : ℕ} [NeZero N]
    (C : GridSmallSimplex d N) (ε : ℝ) : Prop :=
  ∀ x ∈ C.vertices, ∀ y ∈ C.vertices,
    BarySupDistLe (realiseSimplexGrid x) (realiseSimplexGrid y) ε

theorem mesh_le_of_pairwise_coord_diff_le {d N : ℕ} [NeZero N]
    (C : GridSmallSimplex d N)
    (hcoord :
      ∀ x ∈ C.vertices, ∀ y ∈ C.vertices, ∀ i,
        |((x.1 i : ℤ) - (y.1 i : ℤ))| ≤ 1) :
    C.MeshLe ((1 : ℝ) / (N : ℝ)) := by
  classical
  intro x hx y hy i
  have hNpos : (0 : ℝ) < (N : ℝ) := by
    have hNnat : 0 < N := Nat.pos_of_ne_zero (NeZero.ne N)
    exact_mod_cast hNnat
  have hi := hcoord x hx y hy i
  have hrealInt :
      |(((x.1 i : ℤ) - (y.1 i : ℤ) : ℤ) : ℝ)| ≤ (1 : ℝ) := by
    exact_mod_cast hi
  have hcast :
      (((x.1 i : ℤ) - (y.1 i : ℤ) : ℤ) : ℝ)
        =
      (x.1 i : ℝ) - (y.1 i : ℝ) := by
    norm_num
  have hreal :
      |(x.1 i : ℝ) - (y.1 i : ℝ)| ≤ (1 : ℝ) := by
    simpa [hcast] using hrealInt
  calc
    |realiseSimplexGrid x i - realiseSimplexGrid y i|
        =
        |((x.1 i : ℝ) - (y.1 i : ℝ)) / (N : ℝ)| := by
          simp [realiseSimplexGrid]
          ring_nf
    _ = |(x.1 i : ℝ) - (y.1 i : ℝ)| / (N : ℝ) := by
      rw [abs_div, abs_of_pos hNpos]
    _ ≤ (1 : ℝ) / (N : ℝ) := by
      exact div_le_div_of_nonneg_right hreal hNpos.le

end GridSmallSimplex

/-- The coordinate-difference mesh property needed by the later Brouwer step. -/
def GridSmallSimplexHasUnitCoordinateMesh {d N : ℕ}
    (C : GridSmallSimplex d N) : Prop :=
  ∀ x ∈ C.vertices, ∀ y ∈ C.vertices, ∀ i,
    |((x.1 i : ℤ) - (y.1 i : ℤ))| ≤ 1

namespace GridSmallSimplex

theorem mesh_le_of_unitCoordinateMesh {d N : ℕ} [NeZero N]
    (C : GridSmallSimplex d N)
    (hmesh : GridSmallSimplexHasUnitCoordinateMesh C) :
    C.MeshLe ((1 : ℝ) / (N : ℝ)) :=
  C.mesh_le_of_pairwise_coord_diff_le hmesh

end GridSmallSimplex

namespace BaryFreudenthalDatum

theorem unitCoordinateMesh_toGridSmallSimplex {d N : ℕ}
    (D : BaryFreudenthalDatum d N) :
    GridSmallSimplexHasUnitCoordinateMesh D.toGridSmallSimplex := by
  classical
  intro x hx y hy i
  rw [BaryFreudenthalDatum.toGridSmallSimplex, GridSmallSimplex.vertices] at hx hy
  change x ∈ D.toSimplex.vertices at hx
  change y ∈ D.toSimplex.vertices at hy
  rw [BaryFreudenthalSimplex.mem_vertices_iff] at hx hy
  rcases hx with ⟨a, hax⟩
  rcases hy with ⟨b, hby⟩
  rw [← hax, ← hby]
  exact D.vertex_coord_diff_abs_le_one a b i

end BaryFreudenthalDatum

namespace GridSmallSimplex

theorem unitCoordinateMesh {d N : ℕ}
    (C : GridSmallSimplex d N) :
    GridSmallSimplexHasUnitCoordinateMesh C := by
  classical
  rcases C.2 with ⟨D, hD⟩
  have hmesh := D.unitCoordinateMesh_toGridSmallSimplex
  intro x hx y hy i
  apply hmesh
  · simpa [GridSmallSimplex.vertices, BaryFreudenthalDatum.toGridSmallSimplex, hD]
      using hx
  · simpa [GridSmallSimplex.vertices, BaryFreudenthalDatum.toGridSmallSimplex, hD]
      using hy

end GridSmallSimplex

theorem grid_unit_mesh {d N : ℕ} :
    ∀ C : GridSmallSimplex d N,
      GridSmallSimplexHasUnitCoordinateMesh C :=
  GridSmallSimplex.unitCoordinateMesh

namespace BaryFreudenthalSimplex

theorem vertices_card {d N : ℕ}
    (σ : BaryFreudenthalSimplex d N) :
    σ.vertices.card = d + 1 := by
  classical
  rw [BaryFreudenthalSimplex.vertices]
  rw [Finset.card_image_of_injective _ σ.vertex_injective]
  simp [Fintype.card_fin]

end BaryFreudenthalSimplex

/-
Warning (incomplete / upward-only):
The `IsGridSmallSimplex`/datum-generated cells are upward-only — every cell has
the form `{b + eⱼ : j}`. For `d ≥ 2`, distinct such cells share at most one
vertex, so every facet is incident to exactly one cell
(`GeometricGridFacet.boundary_of_two_le_dim`): this is NOT a triangulation of the
standard simplex grid, and boundary oddness for Sperner cannot hold for it. Incidence, local parity, and unit mesh are proved over it, but the full
Sperner route needs the Kuhn/Freudenthal triangulation of the
hypersimplex slices — see `KuhnGrid.lean` (`IsKuhnGridSmallSimplex`), which
generates both the upward (`k = 1`) and downward (`k ≥ 2`) cells.

`IsGridSmallSimplex` is the theorem-facing notion of a small simplex.
The datum witness is only a generator/existence certificate. Incidence and
boundary arguments should count these geometric vertex sets, not raw data.
-/
def IsGridSmallSimplex {d N : ℕ}
    (S : Finset (SimplexGrid d N)) : Prop :=
  S.card = d + 1 ∧
    (∀ x ∈ S, ∀ y ∈ S, ∀ i : Fin (d + 1),
      |((x.1 i : ℤ) - (y.1 i : ℤ))| ≤ 1) ∧
    ∃ D : BaryFreudenthalDatum d N,
      D.toSimplex.vertices = S

/-- A single directed unit grid step between two simplex-grid vertices. -/
def ConsecutiveGridStep {d N : ℕ}
    (x y : SimplexGrid d N) : Prop :=
  ∃ src tgt : Fin (d + 1),
    SimplexGrid.IsDirectedTransfer x y src tgt

theorem SimplexGrid.IsDirectedTransfer.diffSupport_eq_pair {d N : ℕ}
    {x y : SimplexGrid d N}
    {src tgt : Fin (d + 1)}
    (h : SimplexGrid.IsDirectedTransfer x y src tgt) :
    SimplexGrid.diffSupport x y =
      ({src, tgt} : Finset (Fin (d + 1))) := by
  classical
  rcases h with ⟨hneq, hsrc, htgt, hsame⟩
  ext i
  by_cases hi_src : i = src
  · subst i
    have hchanged : x.1 src ≠ y.1 src := by omega
    simp [SimplexGrid.diffSupport, hchanged, hneq]
  · by_cases hi_tgt : i = tgt
    · subst i
      have hchanged : x.1 tgt ≠ y.1 tgt := by omega
      simp [SimplexGrid.diffSupport, hchanged, hi_src]
    · have hsame_i : x.1 i = y.1 i := (hsame i hi_src hi_tgt).symm
      simp [SimplexGrid.diffSupport, hsame_i, hi_src, hi_tgt]

theorem SimplexGrid.IsDirectedTransfer.diffSupport_card_eq_two {d N : ℕ}
    {x y : SimplexGrid d N}
    {src tgt : Fin (d + 1)}
    (h : SimplexGrid.IsDirectedTransfer x y src tgt) :
    (SimplexGrid.diffSupport x y).card = 2 := by
  classical
  rw [SimplexGrid.IsDirectedTransfer.diffSupport_eq_pair h]
  simp [h.1]

theorem ConsecutiveGridStep.unique {d N : ℕ}
    {x y : SimplexGrid d N}
    {s₁ t₁ s₂ t₂ : Fin (d + 1)}
    (h₁ : SimplexGrid.IsDirectedTransfer x y s₁ t₁)
    (h₂ : SimplexGrid.IsDirectedTransfer x y s₂ t₂) :
    s₁ = s₂ ∧ t₁ = t₂ :=
  SimplexGrid.IsDirectedTransfer.unique h₁ h₂

theorem ConsecutiveGridStep.diffSupport_card_eq_two {d N : ℕ}
    {x y : SimplexGrid d N}
    (h : ConsecutiveGridStep x y) :
    (SimplexGrid.diffSupport x y).card = 2 := by
  classical
  rcases h with ⟨src, tgt, htransfer⟩
  exact SimplexGrid.IsDirectedTransfer.diffSupport_card_eq_two htransfer

theorem ConsecutiveGridStep.ne {d N : ℕ}
    {x y : SimplexGrid d N}
    (h : ConsecutiveGridStep x y) :
    x ≠ y := by
  intro hxy
  subst y
  rcases h with ⟨src, _tgt, htransfer⟩
  have hsrc : x.1 src + 1 = x.1 src := htransfer.2.1
  omega

/--
A theorem-facing chain/rank representation for a geometric grid simplex.
The order lists the vertices by rank, and consecutive ranks differ by one
directed grid transfer.
-/
def IsGridSimplexChain {d N : ℕ}
    (S : Finset (SimplexGrid d N)) : Prop :=
  ∃ order : Fin (d + 1) → SimplexGrid d N,
    Function.Injective order ∧
    S = Finset.univ.image order ∧
    ∀ r : Fin d,
      ConsecutiveGridStep
        (order (stepFromIndex r))
        (order (stepToIndex r))

/-- A finite vertex set presented as an ordered list of length `n`. -/
def IsFiniteChainSet {α : Type*} [DecidableEq α]
    (n : ℕ)
    (S : Finset α) : Prop :=
  ∃ order : Fin n → α,
    Function.Injective order ∧
    S = Finset.univ.image order

/-
A mere ordered finite set is insufficient for the ≤2 completion theorem.
We need rank/adjacency data: a completion must insert a vertex into one of the
gaps of the existing chain while preserving consecutive grid-step structure.
-/

/--
An abstract finite chain of length `d + 1`, with consecutive ranks related by
the supplied step relation.
-/
def IsFiniteStepChainSucc {α : Type*} [DecidableEq α]
    (Step : α → α → Prop)
    (d : ℕ)
    (S : Finset α) : Prop :=
  ∃ order : Fin (d + 1) → α,
    Function.Injective order ∧
    S = Finset.univ.image order ∧
    ∀ r : Fin d,
      Step
        (order (stepFromIndex r))
        (order (stepToIndex r))

theorem IsFiniteStepChainSucc.card {α : Type*} [DecidableEq α]
    {Step : α → α → Prop}
    {d : ℕ}
    {S : Finset α}
    (h : IsFiniteStepChainSucc Step d S) :
    S.card = d + 1 := by
  classical
  rcases h with ⟨order, hinj, hS, _⟩
  rw [hS]
  rw [Finset.card_image_of_injective _ hinj]
  simp [Fintype.card_fin]

/-- Candidate vertices whose insertion completes `F` to an abstract step chain. -/
noncomputable def StepChainCompletions {α : Type*} [DecidableEq α] [Fintype α]
    (Step : α → α → Prop)
    (d : ℕ)
    (F : Finset α) :
    Finset α := by
  classical
  exact Finset.univ.filter fun v =>
    IsFiniteStepChainSucc Step d (insert v F)

/-
Warning: this abstraction is too weak for grid incidence.
`StepChainHasAtMostTwoCompletions ConsecutiveGridStep d` is false:
bare consecutive-step chains can have spurious completions that violate
the coordinatewise small-simplex locality condition.
The incidence proof must use `IsGridSmallSimplex (insert v F.vertices)`,
not just `IsFiniteStepChainSucc`. The true bound is proved geometrically as
`GeometricGridFacet.completingOppositeVertices_card_le_two`.
-/

/--
Abstract local incidence property for a step relation: every codimension-one
vertex set has at most two step-chain completions.
-/
def StepChainHasAtMostTwoCompletions {α : Type*} [DecidableEq α] [Fintype α]
    (Step : α → α → Prop)
    (d : ℕ) : Prop :=
  ∀ F : Finset α,
    (StepChainCompletions Step d F).card ≤ 2

theorem StepChainCompletions.not_mem_base {α : Type*} [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    {v : α}
    (hv : v ∈ StepChainCompletions Step d F)
    (hFcard : F.card = d) :
    v ∉ F := by
  classical
  intro hvF
  have hchain :
      IsFiniteStepChainSucc Step d (insert v F) := by
    simpa [StepChainCompletions] using hv
  have hinsert_card :
      (insert v F).card = d + 1 :=
    IsFiniteStepChainSucc.card hchain
  have hinsert_card_base :
      (insert v F).card = d := by
    simpa [Finset.insert_eq_of_mem hvF] using hFcard
  omega

theorem StepChainCompletions.rank_vertex_not_in_base {α : Type*}
    [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    {v : α}
    (hv : v ∈ StepChainCompletions Step d F)
    (hFcard : F.card = d) :
    v ∉ F :=
  StepChainCompletions.not_mem_base hv hFcard

theorem StepChainCompletions.exists_order {α : Type*} [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    {v : α}
    (hv : v ∈ StepChainCompletions Step d F) :
    ∃ order : Fin (d + 1) → α,
      Function.Injective order ∧
      insert v F = Finset.univ.image order ∧
      (∀ r : Fin d,
        Step
          (order (stepFromIndex r))
          (order (stepToIndex r))) := by
  classical
  have hchain :
      IsFiniteStepChainSucc Step d (insert v F) := by
    simpa [StepChainCompletions] using hv
  rcases hchain with ⟨order, hinj, hvertices, hsteps⟩
  exact ⟨order, hinj, hvertices, hsteps⟩

theorem StepChainCompletions.exists_rank {α : Type*} [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    {v : α}
    (hv : v ∈ StepChainCompletions Step d F) :
    ∃ order : Fin (d + 1) → α,
    ∃ r : Fin (d + 1),
      Function.Injective order ∧
      insert v F = Finset.univ.image order ∧
      order r = v ∧
      (∀ k : Fin d,
        Step
          (order (stepFromIndex k))
          (order (stepToIndex k))) := by
  classical
  rcases StepChainCompletions.exists_order (Step := Step) (d := d)
      (F := F) (v := v) hv with
    ⟨order, hinj, hvertices, hsteps⟩
  have hv_insert : v ∈ insert v F := by simp
  have hv_image : v ∈ Finset.univ.image order := by
    simpa [hvertices] using hv_insert
  rcases Finset.mem_image.mp hv_image with ⟨r, _hr, hr⟩
  exact ⟨order, r, hinj, hvertices, hr, hsteps⟩

def StepChainCompletions.HasRank {α : Type*} [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    (F : Finset α)
    (v : α)
    (r : Fin (d + 1)) : Prop :=
  ∃ order : Fin (d + 1) → α,
    Function.Injective order ∧
    insert v F = Finset.univ.image order ∧
    order r = v ∧
    (∀ k : Fin d,
      Step
        (order (stepFromIndex k))
        (order (stepToIndex k)))

theorem StepChainCompletions.exists_hasRank {α : Type*}
    [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    {v : α}
    (hv : v ∈ StepChainCompletions Step d F) :
    ∃ r : Fin (d + 1),
      StepChainCompletions.HasRank (Step := Step) F v r := by
  classical
  rcases StepChainCompletions.exists_rank (Step := Step) (d := d)
      (F := F) (v := v) hv with
    ⟨order, r, hinj, hset, hr, hstep⟩
  exact ⟨r, order, hinj, hset, hr, hstep⟩

noncomputable def StepChainCompletions.ranks {α : Type*}
    [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    (F : Finset α) :
    Finset (Fin (d + 1)) := by
  classical
  exact Finset.univ.filter fun r =>
    ∃ v ∈ StepChainCompletions Step d F,
      StepChainCompletions.HasRank (Step := Step) F v r

theorem StepChainCompletions.mem_ranks_iff {α : Type*}
    [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    (F : Finset α)
    (r : Fin (d + 1)) :
    r ∈ StepChainCompletions.ranks (Step := Step) (d := d) F ↔
      ∃ v ∈ StepChainCompletions Step d F,
        StepChainCompletions.HasRank (Step := Step) F v r := by
  classical
  simp [StepChainCompletions.ranks]

def skipRank {d : ℕ}
    (r : Fin (d + 1)) :
    Fin d → Fin (d + 1) :=
  fun k =>
    if h : k.val < r.val then
      ⟨k.val, by omega⟩
    else
      ⟨k.val + 1, by omega⟩

theorem skipRank_ne {d : ℕ}
    (r : Fin (d + 1))
    (k : Fin d) :
    skipRank r k ≠ r := by
  classical
  unfold skipRank
  split_ifs with h
  · intro hEq
    have hval : k.val = r.val := Fin.ext_iff.mp hEq
    omega
  · intro hEq
    have hval : k.val + 1 = r.val := Fin.ext_iff.mp hEq
    omega

theorem skipRank_injective {d : ℕ}
    (r : Fin (d + 1)) :
    Function.Injective (skipRank r) := by
  classical
  intro a b h
  by_cases ha : a.val < r.val
  · by_cases hb : b.val < r.val
    · have hv : a.val = b.val := by
        simpa [skipRank, ha, hb] using congrArg Fin.val h
      exact Fin.ext hv
    · have hv : a.val = b.val + 1 := by
        simpa [skipRank, ha, hb] using congrArg Fin.val h
      have hble : r.val ≤ b.val := Nat.le_of_not_gt hb
      exact False.elim (by omega)
  · by_cases hb : b.val < r.val
    · have hv : a.val + 1 = b.val := by
        simpa [skipRank, ha, hb] using congrArg Fin.val h
      have hale : r.val ≤ a.val := Nat.le_of_not_gt ha
      exact False.elim (by omega)
    · have hv : a.val + 1 = b.val + 1 := by
        simpa [skipRank, ha, hb] using congrArg Fin.val h
      apply Fin.ext
      omega

theorem mem_image_skipRank_iff {d : ℕ}
    (r : Fin (d + 1))
    (j : Fin (d + 1)) :
    j ∈ Finset.univ.image (skipRank r) ↔ j ≠ r := by
  classical
  constructor
  · intro hj
    rcases Finset.mem_image.mp hj with ⟨k, _hk, hk⟩
    simpa [hk] using skipRank_ne r k
  · intro hj
    by_cases hlt : j.val < r.val
    · have hjd : j.val < d := by omega
      refine Finset.mem_image.mpr ⟨⟨j.val, hjd⟩, by simp, ?_⟩
      apply Fin.ext
      simp [skipRank, hlt]
    · have hrlt : r.val < j.val := by
        have hne_val : j.val ≠ r.val := by
          intro hval
          exact hj (Fin.ext hval)
        omega
      refine Finset.mem_image.mpr
        ⟨⟨j.val - 1, by omega⟩, by simp, ?_⟩
      apply Fin.ext
      have hnot : ¬ j.val - 1 < r.val := by omega
      simp [skipRank, hnot]
      omega

def deleteRankOrder {α : Type*}
    {d : ℕ}
    (order : Fin (d + 1) → α)
    (r : Fin (d + 1)) :
    Fin d → α :=
  fun k => order (skipRank r k)

theorem deleteRankOrder_injective {α : Type*}
    {d : ℕ}
    {order : Fin (d + 1) → α}
    {r : Fin (d + 1)}
    (hinj : Function.Injective order) :
    Function.Injective (deleteRankOrder order r) := by
  intro a b h
  apply skipRank_injective r
  exact hinj h

theorem image_deleteRankOrder_eq_erase {α : Type*} [DecidableEq α]
    {d : ℕ}
    {order : Fin (d + 1) → α}
    {r : Fin (d + 1)}
    (hinj : Function.Injective order) :
    Finset.univ.image (deleteRankOrder order r) =
      (Finset.univ.image order).erase (order r) := by
  classical
  ext x
  constructor
  · intro hx
    rcases Finset.mem_image.mp hx with ⟨k, _hk, rfl⟩
    apply Finset.mem_erase.mpr
    constructor
    · intro hEq
      have hidx : skipRank r k = r := hinj hEq
      exact skipRank_ne r k hidx
    · exact Finset.mem_image.mpr ⟨skipRank r k, by simp, rfl⟩
  · intro hx
    rcases Finset.mem_erase.mp hx with ⟨hxne, hximg⟩
    rcases Finset.mem_image.mp hximg with ⟨j, _hj, hj⟩
    have hjne : j ≠ r := by
      intro h
      apply hxne
      simpa [h] using hj.symm
    have hjimg : j ∈ Finset.univ.image (skipRank r) :=
      (mem_image_skipRank_iff r j).mpr hjne
    rcases Finset.mem_image.mp hjimg with ⟨k, _hk, hk⟩
    refine Finset.mem_image.mpr ⟨k, by simp, ?_⟩
    rw [deleteRankOrder, hk]
    exact hj

/--
An explicit ordering of a base facet together with the rank where a completing
vertex should be inserted.
-/
structure GappedStepChain {α : Type*} [DecidableEq α]
    (Step : α → α → Prop)
    (d : ℕ)
    (F : Finset α) where
  order : Fin d → α
  injective_order : Function.Injective order
  image_order : F = Finset.univ.image order
  gap : Fin (d + 1)

namespace GappedStepChain

/-- Insert a vertex into the explicit gap of a base chain. -/
noncomputable def insertOrder {α : Type*} [DecidableEq α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    (G : GappedStepChain Step d F)
    (v : α) :
    Fin (d + 1) → α :=
  fun k =>
    if h : k.val < G.gap.val then
      G.order ⟨k.val, by omega⟩
    else if hgap : k = G.gap then
      v
    else
      G.order ⟨k.val - 1, by
        have hle : G.gap.val ≤ k.val := Nat.le_of_not_gt h
        have hne : k.val ≠ G.gap.val := by
          intro hval
          exact hgap (Fin.ext hval)
        omega⟩

/-- A vertex completes a gapped chain when inserting it yields a full step chain. -/
def Completes {α : Type*} [DecidableEq α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    (G : GappedStepChain Step d F)
    (v : α) : Prop :=
  v ∉ F ∧
  Function.Injective (G.insertOrder v) ∧
  insert v F = Finset.univ.image (G.insertOrder v) ∧
  ∀ k : Fin d,
    Step
      ((G.insertOrder v) (stepFromIndex k))
      ((G.insertOrder v) (stepToIndex k))

theorem insertOrder_of_lt {α : Type*} [DecidableEq α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    (G : GappedStepChain Step d F)
    (v : α)
    {k : Fin (d + 1)}
    (h : k.val < G.gap.val) :
    G.insertOrder v k = G.order ⟨k.val, by omega⟩ := by
  classical
  simp [insertOrder, h]

theorem insertOrder_gap {α : Type*} [DecidableEq α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    (G : GappedStepChain Step d F)
    (v : α) :
    G.insertOrder v G.gap = v := by
  classical
  simp [insertOrder]

theorem insertOrder_of_gt {α : Type*} [DecidableEq α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    (G : GappedStepChain Step d F)
    (v : α)
    {k : Fin (d + 1)}
    (h : G.gap.val < k.val) :
    G.insertOrder v k = G.order ⟨k.val - 1, by omega⟩ := by
  classical
  have hnot_lt : ¬ k.val < G.gap.val := by omega
  have hnot_gap : ¬ k = G.gap := by
    intro hk
    have hval := congrArg Fin.val hk
    omega
  simp [insertOrder, hnot_lt, hnot_gap]

end GappedStepChain

theorem insertOrder_deleteRankOrder {α : Type*} [DecidableEq α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    (order : Fin (d + 1) → α)
    (r : Fin (d + 1))
    (hinj : Function.Injective (deleteRankOrder order r))
    (himage : F = Finset.univ.image (deleteRankOrder order r)) :
    (GappedStepChain.insertOrder
      ({ order := deleteRankOrder order r
         injective_order := hinj
         image_order := himage
         gap := r } : GappedStepChain Step d F)
      (order r)) =
      order := by
  classical
  funext k
  simp only [GappedStepChain.insertOrder]
  split_ifs with hlt hgap
  · unfold deleteRankOrder
    congr 1
    apply Fin.ext
    simp [skipRank, hlt]
  · exact congrArg order hgap.symm
  · have hne_val : k.val ≠ r.val := by
      intro hval
      exact hgap (Fin.ext hval)
    have hrlt : r.val < k.val := by omega
    unfold deleteRankOrder
    congr 1
    apply Fin.ext
    have hnot : ¬ k.val - 1 < r.val := by omega
    simp [skipRank, hnot]
    omega

theorem StepChainCompletions.exists_gappedChain {α : Type*}
    [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    {v : α}
    (hv : v ∈ StepChainCompletions Step d F)
    (hFcard : F.card = d) :
    ∃ G : GappedStepChain Step d F,
      G.Completes v := by
  classical
  rcases StepChainCompletions.exists_rank (Step := Step) (d := d)
      (F := F) (v := v) hv with
    ⟨order, r, hinj, hset, hr, hstep⟩
  let baseOrder := deleteRankOrder order r
  have hbase_inj : Function.Injective baseOrder :=
    deleteRankOrder_injective hinj
  have hvnot : v ∉ F :=
    StepChainCompletions.not_mem_base hv hFcard
  have himage_base :
      Finset.univ.image baseOrder =
        (Finset.univ.image order).erase (order r) := by
    simpa [baseOrder] using image_deleteRankOrder_eq_erase (order := order)
      (r := r) hinj
  have herase_insert :
      (insert v F).erase v = F := by
    ext x
    by_cases hxv : x = v
    · subst x
      simp [hvnot]
    · simp [hxv]
  have himage : F = Finset.univ.image baseOrder := by
    rw [himage_base]
    rw [← hset]
    rw [hr]
    exact herase_insert.symm
  let G : GappedStepChain Step d F :=
    { order := baseOrder
      injective_order := hbase_inj
      image_order := himage
      gap := r }
  refine ⟨G, ?_⟩
  have hreconstruct :
      G.insertOrder v = order := by
    simpa [G, hr] using
      insertOrder_deleteRankOrder (Step := Step) (F := F)
        order r hbase_inj himage
  refine ⟨hvnot, ?_, ?_, ?_⟩
  · intro a b h
    apply hinj
    simpa [hreconstruct] using h
  · simpa [hreconstruct] using hset
  · intro k
    simpa [hreconstruct] using hstep k

namespace GappedStepChain

theorem completes_step_to_next_of_gap_zero {d N : ℕ}
    {F : Finset (SimplexGrid d N)}
    (G : GappedStepChain
      (ConsecutiveGridStep : SimplexGrid d N → SimplexGrid d N → Prop)
      d F)
    {v : SimplexGrid d N}
    (hv : G.Completes v)
    (hgap : G.gap.val = 0)
    (hd : 0 < d) :
    ConsecutiveGridStep v (G.order ⟨0, hd⟩) := by
  classical
  rcases hv with ⟨_, _, _, hsteps⟩
  let k : Fin d := ⟨0, hd⟩
  have hstep := hsteps k
  have hfrom : G.insertOrder v (stepFromIndex k) = v := by
    have hidx : stepFromIndex k = G.gap := by
      apply Fin.ext
      simp [stepFromIndex, k, hgap]
    simpa [hidx] using G.insertOrder_gap v
  have hto : G.insertOrder v (stepToIndex k) = G.order ⟨0, hd⟩ := by
    have hgt : G.gap.val < (stepToIndex k).val := by
      simp [stepToIndex, k, hgap]
    have h := G.insertOrder_of_gt v (k := stepToIndex k) hgt
    simpa [stepToIndex, k] using h
  simpa [hfrom, hto] using hstep

theorem completes_step_from_prev_of_gap_last {d N : ℕ}
    {F : Finset (SimplexGrid d N)}
    (G : GappedStepChain
      (ConsecutiveGridStep : SimplexGrid d N → SimplexGrid d N → Prop)
      d F)
    {v : SimplexGrid d N}
    (hv : G.Completes v)
    (hgap : G.gap.val = d)
    (hd : 0 < d) :
    ConsecutiveGridStep (G.order ⟨d - 1, by omega⟩) v := by
  classical
  rcases hv with ⟨_, _, _, hsteps⟩
  let k : Fin d := ⟨d - 1, by omega⟩
  have hstep := hsteps k
  have hfrom :
      G.insertOrder v (stepFromIndex k) =
        G.order ⟨d - 1, by omega⟩ := by
    have hlt : (stepFromIndex k).val < G.gap.val := by
      simp [stepFromIndex, k, hgap]
      omega
    have h := G.insertOrder_of_lt v (k := stepFromIndex k) hlt
    simpa [stepFromIndex, k] using h
  have hto : G.insertOrder v (stepToIndex k) = v := by
    have hidx : stepToIndex k = G.gap := by
      apply Fin.ext
      simp [stepToIndex, k, hgap]
      omega
    simpa [hidx] using G.insertOrder_gap v
  simpa [hfrom, hto] using hstep

theorem completes_step_from_prev_of_gap_middle {d N : ℕ}
    {F : Finset (SimplexGrid d N)}
    (G : GappedStepChain
      (ConsecutiveGridStep : SimplexGrid d N → SimplexGrid d N → Prop)
      d F)
    {v : SimplexGrid d N}
    (hv : G.Completes v)
    (hpos : 0 < G.gap.val)
    (hlt : G.gap.val < d) :
    ConsecutiveGridStep (G.order ⟨G.gap.val - 1, by omega⟩) v := by
  classical
  rcases hv with ⟨_, _, _, hsteps⟩
  let k : Fin d := ⟨G.gap.val - 1, by omega⟩
  have hstep := hsteps k
  have hfrom :
      G.insertOrder v (stepFromIndex k) =
        G.order ⟨G.gap.val - 1, by omega⟩ := by
    have hlt' : (stepFromIndex k).val < G.gap.val := by
      change k.val < G.gap.val
      change G.gap.val - 1 < G.gap.val
      omega
    have h := G.insertOrder_of_lt v (k := stepFromIndex k) hlt'
    simpa [stepFromIndex, k] using h
  have hto : G.insertOrder v (stepToIndex k) = v := by
    have hidx : stepToIndex k = G.gap := by
      apply Fin.ext
      simp [stepToIndex, k]
      omega
    simpa [hidx] using G.insertOrder_gap v
  simpa [hfrom, hto] using hstep

theorem completes_step_to_next_of_gap_middle {d N : ℕ}
    {F : Finset (SimplexGrid d N)}
    (G : GappedStepChain
      (ConsecutiveGridStep : SimplexGrid d N → SimplexGrid d N → Prop)
      d F)
    {v : SimplexGrid d N}
    (hv : G.Completes v)
    (_hpos : 0 < G.gap.val)
    (hlt : G.gap.val < d) :
    ConsecutiveGridStep v (G.order ⟨G.gap.val, hlt⟩) := by
  classical
  rcases hv with ⟨_, _, _, hsteps⟩
  let k : Fin d := ⟨G.gap.val, hlt⟩
  have hstep := hsteps k
  have hfrom : G.insertOrder v (stepFromIndex k) = v := by
    have hidx : stepFromIndex k = G.gap := by
      apply Fin.ext
      simp [stepFromIndex, k]
    simpa [hidx] using G.insertOrder_gap v
  have hto :
      G.insertOrder v (stepToIndex k) =
        G.order ⟨G.gap.val, hlt⟩ := by
    have hgt : G.gap.val < (stepToIndex k).val := by
      simp [stepToIndex, k]
    have h := G.insertOrder_of_gt v (k := stepToIndex k) hgt
    simpa [stepToIndex, k] using h
  simpa [hfrom, hto] using hstep

end GappedStepChain

theorem StepChainCompletions.order_mem_base_of_ne_rank {α : Type*}
    [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    {v : α}
    (hv : v ∈ StepChainCompletions Step d F)
    (_hFcard : F.card = d) :
    ∃ order : Fin (d + 1) → α,
    ∃ r : Fin (d + 1),
      Function.Injective order ∧
      insert v F = Finset.univ.image order ∧
      order r = v ∧
      (∀ k : Fin d,
        Step
          (order (stepFromIndex k))
          (order (stepToIndex k))) ∧
      (∀ k : Fin (d + 1), k ≠ r → order k ∈ F) := by
  classical
  rcases StepChainCompletions.exists_rank (Step := Step) (d := d)
      (F := F) (v := v) hv with
    ⟨order, r, hinj, hset, hr, hstep⟩
  refine ⟨order, r, hinj, hset, hr, hstep, ?_⟩
  intro k hk
  have hk_mem_insert : order k ∈ insert v F := by
    rw [hset]
    exact Finset.mem_image.mpr ⟨k, by simp, rfl⟩
  rw [Finset.mem_insert] at hk_mem_insert
  rcases hk_mem_insert with hk_v | hk_F
  · exfalso
    apply hk
    exact hinj (by rw [hk_v, hr])
  · exact hk_F

theorem StepChainCompletions.exists_neighbour_constraints {α : Type*}
    [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    {v : α}
    (hv : v ∈ StepChainCompletions Step d F)
    (hFcard : F.card = d) :
    ∃ order : Fin (d + 1) → α,
    ∃ r : Fin (d + 1),
      Function.Injective order ∧
      insert v F = Finset.univ.image order ∧
      order r = v ∧
      (∀ k : Fin d,
        Step
          (order (stepFromIndex k))
          (order (stepToIndex k))) ∧
      (∀ k : Fin (d + 1), k ≠ r → order k ∈ F) ∧
      (0 < r.val → ∃ p : α, p ∈ F ∧ Step p v) ∧
      (r.val < d → ∃ q : α, q ∈ F ∧ Step v q) := by
  classical
  rcases StepChainCompletions.order_mem_base_of_ne_rank (Step := Step)
      (d := d) (F := F) (v := v) hv hFcard with
    ⟨order, r, hinj, hset, hr, hsteps, hmem⟩
  refine ⟨order, r, hinj, hset, hr, hsteps, hmem, ?_, ?_⟩
  · intro hpos
    let k : Fin d := ⟨r.val - 1, by omega⟩
    have hto : stepToIndex k = r := by
      apply Fin.ext
      simp [stepToIndex, k]
      omega
    have hfrom_ne : stepFromIndex k ≠ r := by
      intro h
      have hval := congrArg Fin.val h
      simp [stepFromIndex, k] at hval
      omega
    refine ⟨order (stepFromIndex k), hmem (stepFromIndex k) hfrom_ne, ?_⟩
    simpa [hto, hr] using hsteps k
  · intro hlt
    let k : Fin d := ⟨r.val, hlt⟩
    have hfrom : stepFromIndex k = r := by
      apply Fin.ext
      simp [stepFromIndex, k]
    have hto_ne : stepToIndex k ≠ r := by
      intro h
      have hval := congrArg Fin.val h
      simp [stepToIndex, k] at hval
    refine ⟨order (stepToIndex k), hmem (stepToIndex k) hto_ne, ?_⟩
    simpa [hfrom, hr] using hsteps k

theorem StepChainCompletions.exists_previous_step {α : Type*}
    [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    {v : α}
    (hv : v ∈ StepChainCompletions Step d F)
    (hFcard : F.card = d) :
    ∃ order : Fin (d + 1) → α,
    ∃ r : Fin (d + 1),
      Function.Injective order ∧
      insert v F = Finset.univ.image order ∧
      order r = v ∧
      (∀ k : Fin d,
        Step
          (order (stepFromIndex k))
          (order (stepToIndex k))) ∧
      (∀ k : Fin (d + 1), k ≠ r → order k ∈ F) ∧
      (0 < r.val → ∃ p : α, p ∈ F ∧ Step p v) := by
  classical
  rcases StepChainCompletions.exists_neighbour_constraints (Step := Step)
      (d := d) (F := F) (v := v) hv hFcard with
    ⟨order, r, hinj, hset, hr, hsteps, hmem, hprev, _hnext⟩
  exact ⟨order, r, hinj, hset, hr, hsteps, hmem, hprev⟩

theorem StepChainCompletions.exists_next_step {α : Type*}
    [DecidableEq α] [Fintype α]
    {Step : α → α → Prop}
    {d : ℕ}
    {F : Finset α}
    {v : α}
    (hv : v ∈ StepChainCompletions Step d F)
    (hFcard : F.card = d) :
    ∃ order : Fin (d + 1) → α,
    ∃ r : Fin (d + 1),
      Function.Injective order ∧
      insert v F = Finset.univ.image order ∧
      order r = v ∧
      (∀ k : Fin d,
        Step
          (order (stepFromIndex k))
          (order (stepToIndex k))) ∧
      (∀ k : Fin (d + 1), k ≠ r → order k ∈ F) ∧
      (r.val < d → ∃ q : α, q ∈ F ∧ Step v q) := by
  classical
  rcases StepChainCompletions.exists_neighbour_constraints (Step := Step)
      (d := d) (F := F) (v := v) hv hFcard with
    ⟨order, r, hinj, hset, hr, hsteps, hmem, _hprev, hnext⟩
  exact ⟨order, r, hinj, hset, hr, hsteps, hmem, hnext⟩

theorem isFiniteStepChainSucc_of_isGridSimplexChain {d N : ℕ}
    {S : Finset (SimplexGrid d N)}
    (hS : IsGridSimplexChain S) :
    IsFiniteStepChainSucc
      (ConsecutiveGridStep : SimplexGrid d N → SimplexGrid d N → Prop)
      d S := by
  simpa [IsGridSimplexChain, IsFiniteStepChainSucc] using hS

theorem isGridSimplexChain_of_isGridSmallSimplex {d N : ℕ}
    {S : Finset (SimplexGrid d N)}
    (hS : IsGridSmallSimplex S) :
    IsGridSimplexChain S := by
  classical
  rcases hS.2.2 with ⟨D, hD⟩
  refine ⟨D.vertex, D.vertex_injective, ?_, ?_⟩
  · simpa [BaryFreudenthalDatum.toSimplex, BaryFreudenthalSimplex.vertices]
      using hD.symm
  · intro r
    refine ⟨D.perm (stepFromIndex r), D.perm (stepToIndex r), ?_⟩
    have hneq :
        D.perm (stepFromIndex r) ≠ D.perm (stepToIndex r) := by
      intro h
      exact stepFromIndex_ne_stepToIndex r (D.perm.injective h)
    have hdir :
        SimplexGrid.IsDirectedTransfer
          (D.vertex (stepFromIndex r))
          (SimplexGrid.transfer
            (D.vertex (stepFromIndex r))
            (D.perm (stepFromIndex r))
            (D.perm (stepToIndex r))
            (baryVertex_source_positive D.base D.perm D.admissible r))
          (D.perm (stepFromIndex r))
          (D.perm (stepToIndex r)) :=
      SimplexGrid.isDirectedTransfer_transfer
        (D.vertex (stepFromIndex r))
        (D.perm (stepFromIndex r))
        (D.perm (stepToIndex r))
        hneq
        (baryVertex_source_positive D.base D.perm D.admissible r)
    rw [D.vertex_succ_eq_transfer r]
    exact hdir

/--
Strengthened canonical small-simplex predicate: a geometric small simplex
together with an exposed chain/rank representation.
-/
def IsCanonicalGridSmallSimplex {d N : ℕ}
    (S : Finset (SimplexGrid d N)) : Prop :=
  IsGridSmallSimplex S ∧ IsGridSimplexChain S

abbrev CanonicalGeometricGridCell (d N : ℕ) :=
  {S : Finset (SimplexGrid d N) // IsCanonicalGridSmallSimplex S}

/--
Canonical theorem-facing geometric grid cells.  The subtype value is the
geometric vertex set; any Freudenthal datum is only a witness that the set is
one of the generated small simplices.
-/
abbrev GeometricGridCell (d N : ℕ) :=
  {S : Finset (SimplexGrid d N) // IsGridSmallSimplex S}

namespace GeometricGridCell

def vertices {d N : ℕ}
    (C : GeometricGridCell d N) :
    Finset (SimplexGrid d N) :=
  C.1

def colourFiber {d N : ℕ}
    (C : GeometricGridCell d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (i : Fin (d + 1)) :
    Finset (SimplexGrid d N) :=
  C.vertices.filter fun x => L x = i

theorem unitMesh {d N : ℕ}
    (C : GeometricGridCell d N) :
    ∀ x ∈ C.vertices, ∀ y ∈ C.vertices, ∀ i : Fin (d + 1),
      |((x.1 i : ℤ) - (y.1 i : ℤ))| ≤ 1 := by
  exact C.2.2.1

/-- A canonical geometric cell has mesh at most `ε` if all realised vertex pairs are that close. -/
def MeshLe {d N : ℕ} [NeZero N]
    (C : GeometricGridCell d N) (ε : ℝ) : Prop :=
  ∀ x ∈ C.vertices, ∀ y ∈ C.vertices,
    BarySupDistLe (realiseSimplexGrid x) (realiseSimplexGrid y) ε

theorem mesh_le_of_pairwise_coord_diff_le {d N : ℕ} [NeZero N]
    (C : GeometricGridCell d N)
    (hcoord :
      ∀ x ∈ C.vertices, ∀ y ∈ C.vertices, ∀ i,
        |((x.1 i : ℤ) - (y.1 i : ℤ))| ≤ 1) :
    C.MeshLe ((1 : ℝ) / (N : ℝ)) := by
  classical
  intro x hx y hy i
  have hNpos : (0 : ℝ) < (N : ℝ) := by
    have hNnat : 0 < N := Nat.pos_of_ne_zero (NeZero.ne N)
    exact_mod_cast hNnat
  have hi := hcoord x hx y hy i
  have hrealInt :
      |(((x.1 i : ℤ) - (y.1 i : ℤ) : ℤ) : ℝ)| ≤ (1 : ℝ) := by
    exact_mod_cast hi
  have hcast :
      (((x.1 i : ℤ) - (y.1 i : ℤ) : ℤ) : ℝ)
        =
      (x.1 i : ℝ) - (y.1 i : ℝ) := by
    norm_num
  have hreal :
      |(x.1 i : ℝ) - (y.1 i : ℝ)| ≤ (1 : ℝ) := by
    simpa [hcast] using hrealInt
  calc
    |realiseSimplexGrid x i - realiseSimplexGrid y i|
        =
        |((x.1 i : ℝ) - (y.1 i : ℝ)) / (N : ℝ)| := by
          simp [realiseSimplexGrid]
          ring_nf
    _ = |(x.1 i : ℝ) - (y.1 i : ℝ)| / (N : ℝ) := by
      rw [abs_div, abs_of_pos hNpos]
    _ ≤ (1 : ℝ) / (N : ℝ) := by
      exact div_le_div_of_nonneg_right hreal hNpos.le

theorem mesh_le_of_unitMesh {d N : ℕ} [NeZero N]
    (C : GeometricGridCell d N)
    (hmesh :
      ∀ x ∈ C.vertices, ∀ y ∈ C.vertices, ∀ i : Fin (d + 1),
        |((x.1 i : ℤ) - (y.1 i : ℤ))| ≤ 1) :
    C.MeshLe ((1 : ℝ) / (N : ℝ)) :=
  C.mesh_le_of_pairwise_coord_diff_le hmesh

end GeometricGridCell

def FullyLabelledGeometricGridCell {d N : ℕ}
    (L : SimplexGrid d N → Fin (d + 1))
    (C : GeometricGridCell d N) : Prop :=
  ∀ i : Fin (d + 1), ∃ x ∈ C.vertices, L x = i

namespace GridSmallSimplex

theorem isGridSmallSimplex {d N : ℕ}
    (C : GridSmallSimplex d N) :
    IsGridSmallSimplex C.vertices := by
  classical
  rcases C.2 with ⟨D, hD⟩
  refine ⟨?_, ?_, ?_⟩
  · rw [GridSmallSimplex.vertices, ← hD]
    exact D.toSimplex.vertices_card
  · exact GridSmallSimplex.unitCoordinateMesh C
  · exact ⟨D, hD⟩

theorem isGridSimplexChain {d N : ℕ}
    (C : GridSmallSimplex d N) :
    IsGridSimplexChain C.vertices :=
  isGridSimplexChain_of_isGridSmallSimplex C.isGridSmallSimplex

theorem isCanonicalGridSmallSimplex {d N : ℕ}
    (C : GridSmallSimplex d N) :
    IsCanonicalGridSmallSimplex C.vertices :=
  ⟨C.isGridSmallSimplex, C.isGridSimplexChain⟩

noncomputable def toGeometricGridCell {d N : ℕ}
    (C : GridSmallSimplex d N) :
    GeometricGridCell d N :=
  ⟨C.vertices, C.isGridSmallSimplex⟩

end GridSmallSimplex

noncomputable instance instGeometricGridCellDecidableEq (d N : ℕ) :
    DecidableEq (GeometricGridCell d N) :=
  Classical.decEq _

/-- All canonical geometric cells generated by the geometric-cell universe. -/
noncomputable def allGeometricGridCells (d N : ℕ) :
    Finset (GeometricGridCell d N) :=
  (allGridSmallSimplices d N).image
    GridSmallSimplex.toGeometricGridCell

theorem mem_allGeometricGridCells {d N : ℕ}
    (C : GeometricGridCell d N) :
    C ∈ allGeometricGridCells d N := by
  classical
  rcases C.2 with ⟨_hcard, _hmesh, D, hD⟩
  let C' : GridSmallSimplex d N := ⟨C.vertices, ⟨D, hD⟩⟩
  refine Finset.mem_image.mpr ⟨C', mem_allGridSmallSimplices C', ?_⟩
  apply Subtype.ext
  rfl

noncomputable instance instGeometricGridCellFintype (d N : ℕ) :
    Fintype (GeometricGridCell d N) :=
  ⟨allGeometricGridCells d N, mem_allGeometricGridCells⟩

def IsGridSmallFacet {d N : ℕ}
    (F : Finset (SimplexGrid d N)) : Prop :=
  ∃ C : GeometricGridCell d N,
    F ⊆ C.vertices ∧
    F.card + 1 = C.vertices.card

/-- Canonical theorem-facing geometric codimension-one facets. -/
abbrev GeometricGridFacet (d N : ℕ) :=
  {F : Finset (SimplexGrid d N) // IsGridSmallFacet F}

namespace GeometricGridFacet

def vertices {d N : ℕ}
    (F : GeometricGridFacet d N) :
    Finset (SimplexGrid d N) :=
  F.1

end GeometricGridFacet

noncomputable instance instGeometricGridFacetDecidableEq (d N : ℕ) :
    DecidableEq (GeometricGridFacet d N) :=
  Classical.decEq _

noncomputable instance instGeometricGridFacetFintype (d N : ℕ) :
    Fintype (GeometricGridFacet d N) :=
  Fintype.ofFinite _

noncomputable instance instDecidableAlmostFullyLabeledGeometricGridFacet {d N : ℕ}
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1)) :
    DecidablePred fun F : GeometricGridFacet d N =>
      EcoLean.Sperner.AlmostFullyLabeled L missing F.vertices := by
  classical
  intro F
  exact Classical.propDecidable _

namespace GeometricGridCell

/-- The canonical geometric facets of a geometric cell, obtained by deleting one vertex. -/
noncomputable def facets {d N : ℕ}
    (C : GeometricGridCell d N) :
    Finset (GeometricGridFacet d N) :=
  C.vertices.attach.image fun x =>
    ⟨C.vertices.erase x.1,
      ⟨C, Finset.erase_subset x.1 C.vertices,
        Finset.card_erase_add_one x.2⟩⟩

theorem mem_facets_iff {d N : ℕ}
    (C : GeometricGridCell d N)
    (F : GeometricGridFacet d N) :
    F ∈ C.facets ↔
      ∃ x ∈ C.vertices, F.vertices = C.vertices.erase x := by
  classical
  constructor
  · intro hF
    rcases Finset.mem_image.mp hF with ⟨x, _hx, hFx⟩
    refine ⟨x.1, x.2, ?_⟩
    exact (congrArg Subtype.val hFx).symm
  · intro hF
    rcases hF with ⟨x, hx, hFx⟩
    refine Finset.mem_image.mpr ⟨⟨x, hx⟩, by simp, ?_⟩
    apply Subtype.ext
    exact hFx.symm

theorem facet_vertices_subset {d N : ℕ}
    (C : GeometricGridCell d N)
    (F : GeometricGridFacet d N)
    (hF : F ∈ C.facets) :
    F.vertices ⊆ C.vertices := by
  classical
  rw [C.mem_facets_iff F] at hF
  rcases hF with ⟨x, _hx, hFx⟩
  intro y hy
  have hy' : y ∈ F.vertices := by
    simpa [GeometricGridFacet.vertices] using hy
  rw [hFx] at hy'
  exact Finset.mem_of_mem_erase hy'

theorem facet_card {d N : ℕ}
    (C : GeometricGridCell d N)
    {F : GeometricGridFacet d N}
    (hF : F ∈ C.facets) :
    F.vertices.card + 1 = C.vertices.card := by
  classical
  rcases (C.mem_facets_iff F).mp hF with ⟨x, hx, hFx⟩
  rw [hFx]
  exact Finset.card_erase_add_one hx

theorem eraseFacet_almostFullyLabeled_iff {d N : ℕ}
    (C : GeometricGridCell d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1))
    {x : SimplexGrid d N}
    (_hx : x ∈ C.vertices) :
    EcoLean.Sperner.AlmostFullyLabeled
      L missing
      (C.vertices.erase x)
      ↔
    ∀ j : Fin (d + 1), j ≠ missing →
      ∃ y ∈ C.vertices.erase x, L y = j := by
  classical
  simp [EcoLean.Sperner.AlmostFullyLabeled,
    EcoLean.Sperner.mem_labelsOn_iff]

end GeometricGridCell

theorem exists_erase_eq_of_subset_card_add_one
    {α : Type*} [DecidableEq α]
    {F S : Finset α}
    (hsub : F ⊆ S)
    (hcard : F.card + 1 = S.card) :
    ∃ x ∈ S, F = S.erase x := by
  classical
  have hdiffCard : (S \ F).card = 1 := by
    have hdiff := Finset.card_sdiff_of_subset hsub
    have hle : F.card ≤ S.card := Finset.card_le_card hsub
    rw [hdiff]
    omega
  rcases Finset.card_eq_one.mp hdiffCard with ⟨x, hxset⟩
  have hxDiff : x ∈ S \ F := by
    rw [hxset]
    simp
  have hxS : x ∈ S := (Finset.mem_sdiff.mp hxDiff).1
  have hxNotF : x ∉ F := (Finset.mem_sdiff.mp hxDiff).2
  refine ⟨x, hxS, ?_⟩
  ext y
  constructor
  · intro hyF
    rw [Finset.mem_erase]
    exact ⟨fun hyx => hxNotF (by simpa [hyx] using hyF), hsub hyF⟩
  · intro hyErase
    have hyS : y ∈ S := (Finset.mem_erase.mp hyErase).2
    by_contra hyNotF
    have hyDiff : y ∈ S \ F := by
      rw [Finset.mem_sdiff]
      exact ⟨hyS, hyNotF⟩
    have hyx : y = x := by
      have : y ∈ ({x} : Finset α) := by
        simpa [hxset] using hyDiff
      simpa using this
    exact (Finset.mem_erase.mp hyErase).1 hyx

theorem eq_insert_of_erase_eq
    {α : Type*} [DecidableEq α]
    {S F : Finset α}
    {x : α}
    (hx : x ∈ S)
    (hF : F = S.erase x) :
    S = insert x F := by
  classical
  subst hF
  exact (Finset.insert_erase hx).symm

namespace GeometricGridCell

theorem vertices_eq_insert_of_facet {d N : ℕ}
    (C : GeometricGridCell d N)
    (F : GeometricGridFacet d N)
    (hF : F ∈ C.facets) :
    ∃ x ∈ C.vertices,
      C.vertices = insert x F.vertices := by
  classical
  rcases (C.mem_facets_iff F).mp hF with ⟨x, hx, hFx⟩
  refine ⟨x, hx, ?_⟩
  exact eq_insert_of_erase_eq hx hFx

noncomputable def oppositeVertex {d N : ℕ}
    (C : GeometricGridCell d N)
    (F : GeometricGridFacet d N)
    (hF : F ∈ C.facets) :
    SimplexGrid d N :=
  Classical.choose (C.vertices_eq_insert_of_facet F hF)

theorem oppositeVertex_mem_vertices {d N : ℕ}
    (C : GeometricGridCell d N)
    (F : GeometricGridFacet d N)
    (hF : F ∈ C.facets) :
    C.oppositeVertex F hF ∈ C.vertices := by
  classical
  exact (Classical.choose_spec
    (C.vertices_eq_insert_of_facet F hF)).1

theorem vertices_eq_insert_oppositeVertex {d N : ℕ}
    (C : GeometricGridCell d N)
    (F : GeometricGridFacet d N)
    (hF : F ∈ C.facets) :
    C.vertices =
      insert (C.oppositeVertex F hF) F.vertices := by
  classical
  exact (Classical.choose_spec
    (C.vertices_eq_insert_of_facet F hF)).2

theorem eq_of_same_facet_same_opposite {d N : ℕ}
    {C₁ C₂ : GeometricGridCell d N}
    {F : GeometricGridFacet d N}
    (h₁ : F ∈ C₁.facets)
    (h₂ : F ∈ C₂.facets)
    (hop :
      C₁.oppositeVertex F h₁ =
      C₂.oppositeVertex F h₂) :
    C₁ = C₂ := by
  classical
  apply Subtype.ext
  calc
    C₁.vertices = insert (C₁.oppositeVertex F h₁) F.vertices :=
      C₁.vertices_eq_insert_oppositeVertex F h₁
    _ = insert (C₂.oppositeVertex F h₂) F.vertices := by rw [hop]
    _ = C₂.vertices := by
      symm
      exact C₂.vertices_eq_insert_oppositeVertex F h₂

end GeometricGridCell

namespace FiniteSimplexLocalParity

theorem card_attach_filter_eq_filter
    {α : Type*} [DecidableEq α]
    (S : Finset α) (P : α → Prop) [DecidablePred P] :
    (S.attach.filter fun x => P x.1).card =
      (S.filter P).card := by
  classical
  refine Finset.card_bij
    (fun x hx => x.1) ?_ ?_ ?_
  · intro x hx
    rw [Finset.mem_filter] at hx ⊢
    exact ⟨x.2, hx.2⟩
  · intro x _hx y _hy hxy
    exact Subtype.ext hxy
  · intro y hy
    rw [Finset.mem_filter] at hy
    refine ⟨⟨y, hy.1⟩, ?_, rfl⟩
    rw [Finset.mem_filter]
    exact ⟨by simp, hy.2⟩

theorem odd_relevant_erasures_iff_surjective
    {α ι : Type*}
    [DecidableEq α] [DecidableEq ι] [Fintype ι]
    (S : Finset α)
    (label : α → ι)
    (hcard : S.card = Fintype.card ι)
    (missing : ι) :
    Odd
      ((S.filter fun x =>
        ∀ j : ι, j ≠ missing →
          ∃ y ∈ S.erase x, label y = j).card)
      ↔
    (∀ j : ι, ∃ x ∈ S, label x = j) := by
  classical
  have hcardSubtype :
      Fintype.card {x // x ∈ S} = Fintype.card ι := by
    rw [Fintype.card_coe S, hcard]
  let e : {x // x ∈ S} ≃ ι := Fintype.equivOfCardEq hcardSubtype
  let f : ι → ι := fun k => label ((e.symm k).1)
  have hrel :
      (S.filter fun x =>
        ∀ j : ι, j ≠ missing →
          ∃ y ∈ S.erase x, label y = j).card
        =
      (LocalDeletionParity.relevantOmissions f missing).card := by
    refine Finset.card_bij
      (fun x hx => e ⟨x, (Finset.mem_filter.mp hx).1⟩) ?_ ?_ ?_
    · intro x hx
      rw [LocalDeletionParity.mem_relevantOmissions_iff]
      intro a ha
      have hxprop := (Finset.mem_filter.mp hx).2
      rcases hxprop a ha with ⟨y, hyerase, hlabel⟩
      have hyS : y ∈ S := (Finset.mem_erase.mp hyerase).2
      refine ⟨e ⟨y, hyS⟩, ?_, ?_⟩
      · intro heq
        have hsub : (⟨y, hyS⟩ : {x // x ∈ S}) =
            ⟨x, (Finset.mem_filter.mp hx).1⟩ :=
          e.injective heq
        have hyx : y = x := congrArg Subtype.val hsub
        have hyne : y ≠ x := (Finset.mem_erase.mp hyerase).1
        exact hyne hyx
      · simpa [f] using hlabel
    · intro x hx y hy hxy
      exact congrArg Subtype.val (e.injective hxy)
    · intro k hk
      rw [LocalDeletionParity.mem_relevantOmissions_iff] at hk
      let x : α := (e.symm k).1
      have hxS : x ∈ S := (e.symm k).2
      refine ⟨x, ?_, ?_⟩
      · rw [Finset.mem_filter]
        refine ⟨hxS, ?_⟩
        intro a ha
        rcases hk a ha with ⟨i, hik, hfi⟩
        let y : α := (e.symm i).1
        have hyS : y ∈ S := (e.symm i).2
        refine ⟨y, ?_, ?_⟩
        · rw [Finset.mem_erase]
          refine ⟨?_, hyS⟩
          intro hyx
          apply hik
          have hsub : (e.symm i) = (e.symm k) := by
            apply Subtype.ext
            exact hyx
          exact e.symm.injective hsub
        · simpa [f, y] using hfi
      · exact Equiv.apply_symm_apply e k
  have hsurj :
      Function.Surjective f ↔
        ∀ j : ι, ∃ x ∈ S, label x = j := by
    constructor
    · intro hf j
      rcases hf j with ⟨k, hk⟩
      refine ⟨(e.symm k).1, (e.symm k).2, ?_⟩
      simpa [f] using hk
    · intro hfull j
      rcases hfull j with ⟨x, hxS, hlabel⟩
      refine ⟨e ⟨x, hxS⟩, ?_⟩
      simpa [f] using hlabel
  rw [hrel]
  exact (LocalDeletionParity.odd_relevant_omissions_iff_surjective
    f missing).trans hsurj

end FiniteSimplexLocalParity

namespace GeometricGridCell

theorem localParity {d N : ℕ}
    (C : GeometricGridCell d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1)) :
    Odd
      ((C.facets.filter fun F : GeometricGridFacet d N =>
        EcoLean.Sperner.AlmostFullyLabeled
          L missing F.vertices).card)
      ↔
    FullyLabelledGeometricGridCell L C := by
  classical
  let facetOf :
      {x : SimplexGrid d N // x ∈ C.vertices} →
        GeometricGridFacet d N :=
    fun x =>
      ⟨C.vertices.erase x.1,
        ⟨C, Finset.erase_subset x.1 C.vertices,
          Finset.card_erase_add_one x.2⟩⟩
  have hinj : Function.Injective facetOf := by
    intro x y hxy
    have herase :
        C.vertices.erase x.1 = C.vertices.erase y.1 :=
      congrArg Subtype.val hxy
    have hxyval : x.1 = y.1 := by
      exact (Finset.erase_inj C.vertices x.2).mp herase
    exact Subtype.ext hxyval
  have hcardFacets :
      ((C.facets.filter fun F : GeometricGridFacet d N =>
        EcoLean.Sperner.AlmostFullyLabeled
          L missing F.vertices).card)
        =
      ((C.vertices.attach.filter fun x =>
        EcoLean.Sperner.AlmostFullyLabeled
          L missing (C.vertices.erase x.1)).card) := by
    rw [GeometricGridCell.facets]
    rw [Finset.filter_image]
    rw [Finset.card_image_of_injective _ hinj]
    rfl
  have hcardAttach :
      ((C.vertices.attach.filter fun x =>
        EcoLean.Sperner.AlmostFullyLabeled
          L missing (C.vertices.erase x.1)).card)
        =
      ((C.vertices.filter fun x =>
        EcoLean.Sperner.AlmostFullyLabeled
          L missing (C.vertices.erase x)).card) :=
    FiniteSimplexLocalParity.card_attach_filter_eq_filter
      C.vertices
      (fun x =>
        EcoLean.Sperner.AlmostFullyLabeled
          L missing (C.vertices.erase x))
  have hvertexCard :
      C.vertices.card = Fintype.card (Fin (d + 1)) := by
    simpa [GeometricGridCell.vertices, Fintype.card_fin] using C.2.1
  have hfinite :=
    FiniteSimplexLocalParity.odd_relevant_erasures_iff_surjective
      (α := SimplexGrid d N)
      (ι := Fin (d + 1))
      C.vertices
      L
      hvertexCard
      missing
  have halmost :
      ((C.vertices.filter fun x =>
        EcoLean.Sperner.AlmostFullyLabeled
          L missing (C.vertices.erase x)).card)
        =
      ((C.vertices.filter fun x =>
        ∀ j : Fin (d + 1), j ≠ missing →
          ∃ y ∈ C.vertices.erase x, L y = j).card) := by
    apply congrArg Finset.card
    ext x
    by_cases hx : x ∈ C.vertices
    · simp [hx, C.eraseFacet_almostFullyLabeled_iff L missing hx]
    · simp [hx]
  rw [hcardFacets, hcardAttach, halmost]
  simpa [FullyLabelledGeometricGridCell] using hfinite

end GeometricGridCell

namespace GeometricGridFacet

/-- Canonical geometric cells incident to a canonical geometric facet. -/
noncomputable def incidentCells {d N : ℕ}
    (F : GeometricGridFacet d N) :
    Finset (GeometricGridCell d N) :=
  (allGeometricGridCells d N).filter fun C =>
    F ∈ C.facets

theorem mem_incidentCells_iff {d N : ℕ}
    (F : GeometricGridFacet d N)
    (C : GeometricGridCell d N) :
    C ∈ F.incidentCells ↔
      C ∈ allGeometricGridCells d N ∧ F ∈ C.facets := by
  classical
  simp [incidentCells]

theorem mem_incidentCells_iff_facets {d N : ℕ}
    (F : GeometricGridFacet d N)
    (C : GeometricGridCell d N) :
    C ∈ F.incidentCells ↔ F ∈ C.facets := by
  classical
  rw [F.mem_incidentCells_iff C]
  simp [mem_allGeometricGridCells]

theorem incidentCells_nonempty {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.incidentCells.Nonempty := by
  classical
  rcases F.2 with ⟨C, hsub, hcard⟩
  rcases exists_erase_eq_of_subset_card_add_one
      (F := F.vertices) (S := C.vertices) hsub hcard with
    ⟨x, hxC, hFx⟩
  refine ⟨C, ?_⟩
  rw [F.mem_incidentCells_iff]
  refine ⟨mem_allGeometricGridCells C, ?_⟩
  rw [C.mem_facets_iff F]
  exact ⟨x, hxC, hFx⟩

theorem one_le_incidentCells_card {d N : ℕ}
    (F : GeometricGridFacet d N) :
    1 ≤ F.incidentCells.card := by
  classical
  exact Finset.card_pos.mpr F.incidentCells_nonempty

noncomputable def oppositeVertices {d N : ℕ}
    (F : GeometricGridFacet d N) :
    Finset (SimplexGrid d N) :=
  F.incidentCells.attach.image fun C =>
    C.1.oppositeVertex F
      ((F.mem_incidentCells_iff_facets C.1).mp C.2)

theorem oppositeVertex_mem_oppositeVertices {d N : ℕ}
    (F : GeometricGridFacet d N)
    (C : GeometricGridCell d N)
    (hC : C ∈ F.incidentCells) :
    C.oppositeVertex F
      ((F.mem_incidentCells_iff_facets C).mp hC)
      ∈ F.oppositeVertices := by
  classical
  unfold GeometricGridFacet.oppositeVertices
  exact Finset.mem_image.mpr ⟨⟨C, hC⟩, by simp⟩

theorem incidentCell_to_oppositeVertex_injective {d N : ℕ}
    (F : GeometricGridFacet d N) :
    Function.Injective
      (fun C : {C : GeometricGridCell d N // C ∈ F.incidentCells} =>
        C.1.oppositeVertex F
          ((F.mem_incidentCells_iff_facets C.1).mp C.2)) := by
  classical
  intro C₁ C₂ h
  apply Subtype.ext
  exact GeometricGridCell.eq_of_same_facet_same_opposite
    ((F.mem_incidentCells_iff_facets C₁.1).mp C₁.2)
    ((F.mem_incidentCells_iff_facets C₂.1).mp C₂.2)
    h

theorem oppositeVertices_card_eq_incidentCells_card {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.oppositeVertices.card = F.incidentCells.card := by
  classical
  unfold GeometricGridFacet.oppositeVertices
  rw [Finset.card_image_of_injective _
    (F.incidentCell_to_oppositeVertex_injective)]
  exact Finset.card_attach

theorem incidentCells_card_le_oppositeVertices_card {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.incidentCells.card ≤ F.oppositeVertices.card := by
  classical
  rw [F.oppositeVertices_card_eq_incidentCells_card]

theorem oppositeVertex_coord_close_to_facet {d N : ℕ}
    (F : GeometricGridFacet d N)
    (C : GeometricGridCell d N)
    (hC : C ∈ F.incidentCells)
    (x : SimplexGrid d N)
    (hx : x ∈ F.vertices)
    (i : Fin (d + 1)) :
    |(((C.oppositeVertex F
        ((F.mem_incidentCells_iff_facets C).mp hC)).1 i : ℤ) -
      (x.1 i : ℤ))| ≤ 1 := by
  classical
  let hF : F ∈ C.facets := (F.mem_incidentCells_iff_facets C).mp hC
  have hv :
      C.oppositeVertex F hF ∈ C.vertices :=
    C.oppositeVertex_mem_vertices F hF
  have hxC : x ∈ C.vertices :=
    C.facet_vertices_subset F hF hx
  exact C.unitMesh (C.oppositeVertex F hF) hv x hxC i

noncomputable def coordinateCandidateOpposites {d N : ℕ}
    (F : GeometricGridFacet d N) :
    Finset (SimplexGrid d N) := by
  classical
  exact Finset.univ.filter fun v =>
    ∀ x ∈ F.vertices, ∀ i : Fin (d + 1),
      |((v.1 i : ℤ) - (x.1 i : ℤ))| ≤ 1

theorem oppositeVertices_subset_coordinateCandidates {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.oppositeVertices ⊆ F.coordinateCandidateOpposites := by
  classical
  intro v hv
  rw [GeometricGridFacet.coordinateCandidateOpposites]
  rw [Finset.mem_filter]
  refine ⟨Finset.mem_univ v, ?_⟩
  rw [GeometricGridFacet.oppositeVertices] at hv
  rcases Finset.mem_image.mp hv with ⟨C, _hCmem, hv_eq⟩
  intro x hx i
  have hclose :=
    F.oppositeVertex_coord_close_to_facet C.1 C.2 x hx i
  simpa [hv_eq.symm] using hclose

noncomputable def completingOppositeVertices {d N : ℕ}
    (F : GeometricGridFacet d N) :
    Finset (SimplexGrid d N) := by
  classical
  exact Finset.univ.filter fun v =>
    IsGridSmallSimplex (insert v F.vertices)

theorem mem_completingOppositeVertices_iff {d N : ℕ}
    (F : GeometricGridFacet d N)
    (v : SimplexGrid d N) :
    v ∈ F.completingOppositeVertices ↔
      IsGridSmallSimplex (insert v F.vertices) := by
  classical
  simp [GeometricGridFacet.completingOppositeVertices]

noncomputable def cellOfCompletingVertex {d N : ℕ}
    (F : GeometricGridFacet d N)
    (v : SimplexGrid d N)
    (hv : v ∈ F.completingOppositeVertices) :
    GeometricGridCell d N :=
  ⟨insert v F.vertices,
    (F.mem_completingOppositeVertices_iff v).mp hv⟩

theorem cellOfCompletingVertex_vertices {d N : ℕ}
    (F : GeometricGridFacet d N)
    (v : SimplexGrid d N)
    (hv : v ∈ F.completingOppositeVertices) :
    (F.cellOfCompletingVertex v hv).vertices =
      insert v F.vertices :=
  rfl

theorem card_add_one_eq_cell_card {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.vertices.card + 1 = d + 1 := by
  classical
  rcases F.2 with ⟨C, _hsub, hcard⟩
  calc
    F.vertices.card + 1 = C.vertices.card := hcard
    _ = d + 1 := C.2.1

theorem completingVertex_not_mem {d N : ℕ}
    (F : GeometricGridFacet d N)
    (v : SimplexGrid d N)
    (hv : v ∈ F.completingOppositeVertices) :
    v ∉ F.vertices := by
  classical
  intro hvF
  have hsmall :
      IsGridSmallSimplex (insert v F.vertices) :=
    (F.mem_completingOppositeVertices_iff v).mp hv
  have hinsert_card :
      (insert v F.vertices).card = d + 1 :=
    hsmall.1
  have hFcard_insert :
      F.vertices.card = d + 1 := by
    simpa [Finset.insert_eq_of_mem hvF] using hinsert_card
  have hFcard_add := F.card_add_one_eq_cell_card
  omega

theorem mem_cellOfCompletingVertex_facets {d N : ℕ}
    (F : GeometricGridFacet d N)
    (v : SimplexGrid d N)
    (hv : v ∈ F.completingOppositeVertices)
    (hvnot : v ∉ F.vertices) :
    F ∈ (F.cellOfCompletingVertex v hv).facets := by
  classical
  rw [GeometricGridCell.mem_facets_iff]
  refine ⟨v, ?_, ?_⟩
  · simp [GeometricGridFacet.cellOfCompletingVertex_vertices]
  · simp [GeometricGridFacet.cellOfCompletingVertex_vertices, hvnot]

theorem oppositeVertices_subset_completing {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.oppositeVertices ⊆ F.completingOppositeVertices := by
  classical
  intro v hv
  rw [GeometricGridFacet.completingOppositeVertices]
  rw [Finset.mem_filter]
  refine ⟨Finset.mem_univ v, ?_⟩
  rw [GeometricGridFacet.oppositeVertices] at hv
  rcases Finset.mem_image.mp hv with ⟨C, _hCmem, hv_eq⟩
  let hF : F ∈ C.1.facets := (F.mem_incidentCells_iff_facets C.1).mp C.2
  have hsmall : IsGridSmallSimplex C.1.vertices := C.1.2
  have hverts : C.1.vertices =
      insert (C.1.oppositeVertex F hF) F.vertices :=
    C.1.vertices_eq_insert_oppositeVertex F hF
  rw [hverts] at hsmall
  simpa [hv_eq.symm] using hsmall

theorem cellOfCompletingVertex_injective {d N : ℕ}
    (F : GeometricGridFacet d N) :
    Function.Injective
      (fun v : {v : SimplexGrid d N // v ∈ F.completingOppositeVertices} =>
        F.cellOfCompletingVertex v.1 v.2) := by
  classical
  intro v w hcell
  have hverts :=
    congrArg GeometricGridCell.vertices hcell
  have hvnot : v.1 ∉ F.vertices :=
    F.completingVertex_not_mem v.1 v.2
  have hverts' :
      insert v.1 F.vertices = insert w.1 F.vertices := by
    simpa [GeometricGridFacet.cellOfCompletingVertex_vertices] using hverts
  have hv_mem_insert :
      v.1 ∈ insert w.1 F.vertices := by
    rw [← hverts']
    simp
  have hvw : v.1 = w.1 := by
    rw [Finset.mem_insert] at hv_mem_insert
    rcases hv_mem_insert with hvw | hvF
    · exact hvw
    · exact False.elim (hvnot hvF)
  exact Subtype.ext hvw

noncomputable def completionCells {d N : ℕ}
    (F : GeometricGridFacet d N) :
    Finset (GeometricGridCell d N) :=
  F.completingOppositeVertices.attach.image fun v =>
    F.cellOfCompletingVertex v.1 v.2

theorem completionCells_card_eq {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.completionCells.card = F.completingOppositeVertices.card := by
  classical
  unfold GeometricGridFacet.completionCells
  rw [Finset.card_image_of_injective _
    (F.cellOfCompletingVertex_injective)]
  exact Finset.card_attach

noncomputable def canonicalCompletingOppositeVertices {d N : ℕ}
    (F : GeometricGridFacet d N) :
    Finset (SimplexGrid d N) := by
  classical
  exact Finset.univ.filter fun v =>
    IsCanonicalGridSmallSimplex (insert v F.vertices)

theorem mem_canonicalCompletingOppositeVertices_iff {d N : ℕ}
    (F : GeometricGridFacet d N)
    (v : SimplexGrid d N) :
    v ∈ F.canonicalCompletingOppositeVertices ↔
      IsCanonicalGridSmallSimplex (insert v F.vertices) := by
  classical
  simp [GeometricGridFacet.canonicalCompletingOppositeVertices]

theorem completingOppositeVertices_subset_canonical {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.completingOppositeVertices ⊆
      F.canonicalCompletingOppositeVertices := by
  classical
  intro v hv
  rw [F.mem_canonicalCompletingOppositeVertices_iff]
  have hsmall :
      IsGridSmallSimplex (insert v F.vertices) :=
    (F.mem_completingOppositeVertices_iff v).mp hv
  exact ⟨hsmall, isGridSimplexChain_of_isGridSmallSimplex hsmall⟩

theorem canonicalCompletingOppositeVertices_subset_completing {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.canonicalCompletingOppositeVertices ⊆
      F.completingOppositeVertices := by
  classical
  intro v hv
  rw [F.mem_completingOppositeVertices_iff]
  exact ((F.mem_canonicalCompletingOppositeVertices_iff v).mp hv).1

theorem completingOppositeVertices_card_le_two_of_canonical_bound {d N : ℕ}
    (F : GeometricGridFacet d N)
    (hbound : F.canonicalCompletingOppositeVertices.card ≤ 2) :
    F.completingOppositeVertices.card ≤ 2 :=
  le_trans
    (Finset.card_le_card F.completingOppositeVertices_subset_canonical)
    hbound

theorem canonicalCompletingOppositeVertices_subset_stepChainCompletions {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.canonicalCompletingOppositeVertices ⊆
      StepChainCompletions
        (ConsecutiveGridStep : SimplexGrid d N → SimplexGrid d N → Prop)
        d F.vertices := by
  classical
  intro v hv
  have hcanonical :
      IsCanonicalGridSmallSimplex (insert v F.vertices) :=
    (F.mem_canonicalCompletingOppositeVertices_iff v).mp hv
  simp [StepChainCompletions,
    isFiniteStepChainSucc_of_isGridSimplexChain hcanonical.2]

theorem canonicalCompletingOppositeVertices_card_le_two_of_stepChainCompletions
    {d N : ℕ}
    (hstep :
      StepChainHasAtMostTwoCompletions
        (ConsecutiveGridStep : SimplexGrid d N → SimplexGrid d N → Prop)
        d) :
    ∀ F : GeometricGridFacet d N,
      F.canonicalCompletingOppositeVertices.card ≤ 2 := by
  classical
  intro F
  exact le_trans
    (Finset.card_le_card F.canonicalCompletingOppositeVertices_subset_stepChainCompletions)
    (hstep F.vertices)

/-- A canonical geometric facet is on the boundary when it has one incident cell. -/
def boundary {d N : ℕ}
    (F : GeometricGridFacet d N) : Prop :=
  F.incidentCells.card = 1

theorem boundary_incident_card {d N : ℕ}
    (F : GeometricGridFacet d N)
    (hF : F.boundary) :
    F.incidentCells.card = 1 :=
  hF

end GeometricGridFacet

/--
This is the canonical incidence theorem still to be proved:
every geometric codimension-one facet is incident to either one or two
geometric d-cells.
-/
def GeometricGridIncidenceHypothesis (d N : ℕ) : Prop :=
  ∀ F : GeometricGridFacet d N,
    F.incidentCells.card = 1 ∨ F.incidentCells.card = 2

def GeometricGridOppositeVertexBound (d N : ℕ) : Prop :=
  ∀ F : GeometricGridFacet d N,
    F.oppositeVertices.card ≤ 2

theorem GeometricGridOppositeVertexBound.of_coordinateCandidate_bound {d N : ℕ}
    (h :
      ∀ F : GeometricGridFacet d N,
        F.coordinateCandidateOpposites.card ≤ 2) :
    GeometricGridOppositeVertexBound d N := by
  intro F
  exact le_trans
    (Finset.card_le_card (F.oppositeVertices_subset_coordinateCandidates))
    (h F)

theorem GeometricGridOppositeVertexBound.of_completing_bound {d N : ℕ}
    (h :
      ∀ F : GeometricGridFacet d N,
        F.completingOppositeVertices.card ≤ 2) :
    GeometricGridOppositeVertexBound d N := by
  intro F
  exact le_trans
    (Finset.card_le_card (F.oppositeVertices_subset_completing))
    (h F)

theorem GeometricGridOppositeVertexBound.of_canonicalCompleting_bound {d N : ℕ}
    (h :
      ∀ F : GeometricGridFacet d N,
        F.canonicalCompletingOppositeVertices.card ≤ 2) :
    GeometricGridOppositeVertexBound d N := by
  intro F
  exact le_trans
    (Finset.card_le_card F.oppositeVertices_subset_completing)
    (F.completingOppositeVertices_card_le_two_of_canonical_bound (h F))

theorem GeometricGridOppositeVertexBound.of_stepChainCompletions {d N : ℕ}
    (hstep :
      StepChainHasAtMostTwoCompletions
        (ConsecutiveGridStep : SimplexGrid d N → SimplexGrid d N → Prop)
        d) :
    GeometricGridOppositeVertexBound d N :=
  GeometricGridOppositeVertexBound.of_canonicalCompleting_bound
    (GeometricGridFacet.canonicalCompletingOppositeVertices_card_le_two_of_stepChainCompletions
      hstep)

/-
The remaining local geometry is now isolated as an abstract step-chain
completion property for the concrete grid step relation ConsecutiveGridStep.
This is the canonical replacement for raw Freudenthal incidence.
-/

theorem GeometricGridIncidenceHypothesis.of_oppositeVertexBound {d N : ℕ}
    (hbound : GeometricGridOppositeVertexBound d N) :
    GeometricGridIncidenceHypothesis d N := by
  classical
  intro F
  have hge := F.one_le_incidentCells_card
  have hcard :
      F.incidentCells.card = F.oppositeVertices.card :=
    (F.oppositeVertices_card_eq_incidentCells_card).symm
  have hle : F.incidentCells.card ≤ 2 := by
    rw [hcard]
    exact hbound F
  omega

/-
Canonical incidence is now reduced to `GeometricGridOppositeVertexBound`.
Mathematically this says that a codimension-one geometric facet has at most
two possible opposite grid vertices, one on each side. This is the remaining
local geometric theorem needed for `GeometricGridIncidenceHypothesis`.
-/

/-
Canonical local incidence, proved geometrically.

`StepChainHasAtMostTwoCompletions ConsecutiveGridStep d` is FALSE (bare
consecutive-step chains overcount), so the bound is proved directly from
`IsGridSmallSimplex (insert v F.vertices)`: every small simplex is of the form
`{b + e_j : j}` with `b` the coordinatewise minimum, hence two small simplices
sharing two vertices coincide, and a facet has a unique completion (`d ≥ 2`).
-/
/-- Exact closed form for a datum vertex coordinate, in ℤ. -/
theorem vertex_coord_int_formula {d N : ℕ}
    (D : BaryFreudenthalDatum d N) (k i : Fin (d + 1)) :
    ((D.vertex k).1 i : ℤ)
      = (D.base.1 i : ℤ)
        - (if (D.perm.symm i).val = 0 then (1 : ℤ) else 0)
        + (if i = D.perm k then (1 : ℤ) else 0) := by
  classical
  have hidx : (i = D.perm k) ↔ ((D.perm.symm i).val = k.val) :=
    (Equiv.symm_apply_eq D.perm).symm.trans Fin.ext_iff
  have hadm := D.admissible.1 k i
  dsimp [BaryFreudenthalDatum.vertex, baryVertex]
  rw [outgoingCount_eq_ite, incomingCount_eq_ite] at hadm ⊢
  rw [Nat.cast_sub hadm]
  simp only [hidx]
  push_cast
  split_ifs <;> omega

/-- The integer "base" coordinate of a datum: `base i` minus one at `i = perm 0`. -/
private def bcoordZ {d N : ℕ} (D : BaryFreudenthalDatum d N) (i : Fin (d + 1)) : ℤ :=
  (D.base.1 i : ℤ) - (if (D.perm.symm i).val = 0 then (1 : ℤ) else 0)

theorem vertex_coord_eq_bcoordZ {d N : ℕ}
    (D : BaryFreudenthalDatum d N) (k i : Fin (d + 1)) :
    ((D.vertex k).1 i : ℤ) = bcoordZ D i + (if i = D.perm k then (1 : ℤ) else 0) := by
  rw [vertex_coord_int_formula]; rfl

/-- A vertex `x = D.vertex kx` recovers the coordinate relation in ℤ. -/
theorem coord_eq_of_vertex_eq {d N : ℕ}
    (D : BaryFreudenthalDatum d N) {kx : Fin (d + 1)} {x : SimplexGrid d N}
    (hkx : D.vertex kx = x) (i : Fin (d + 1)) :
    (x.1 i : ℤ) = bcoordZ D i + (if i = D.perm kx then (1 : ℤ) else 0) := by
  rw [← hkx]; exact vertex_coord_eq_bcoordZ D kx i

theorem mem_iff_exists_vertex {d N : ℕ}
    {S : Finset (SimplexGrid d N)} {D : BaryFreudenthalDatum d N}
    (hD : D.toSimplex.vertices = S) (x : SimplexGrid d N) :
    x ∈ S ↔ ∃ k, D.vertex k = x := by
  rw [← hD]
  exact D.mem_vertices_iff x

/-- Two small simplices sharing two distinct vertices are equal. -/
theorem small_simplex_eq_of_two_common {d N : ℕ}
    {S S' : Finset (SimplexGrid d N)}
    (hS : IsGridSmallSimplex S) (hS' : IsGridSmallSimplex S')
    {x y : SimplexGrid d N}
    (hxS : x ∈ S) (hyS : y ∈ S) (hxS' : x ∈ S') (hyS' : y ∈ S')
    (hxy : x ≠ y) :
    S = S' := by
  classical
  obtain ⟨D, hD⟩ := hS.2.2
  obtain ⟨D', hD'⟩ := hS'.2.2
  obtain ⟨kx, hkx⟩ := (mem_iff_exists_vertex hD x).mp hxS
  obtain ⟨ky, hky⟩ := (mem_iff_exists_vertex hD y).mp hyS
  obtain ⟨k'x, hk'x⟩ := (mem_iff_exists_vertex hD' x).mp hxS'
  obtain ⟨k'y, hk'y⟩ := (mem_iff_exists_vertex hD' y).mp hyS'
  set a := D.perm kx with ha
  set c := D.perm ky with hc
  set a' := D'.perm k'x with ha'
  set c' := D'.perm k'y with hc'
  have hkxy : kx ≠ ky := by
    intro h; apply hxy; rw [← hkx, ← hky, h]
  have hac : a ≠ c := fun h => hkxy (D.perm.injective h)
  -- coordinate equations
  have hx : ∀ i, (x.1 i : ℤ) = bcoordZ D i + (if i = a then (1:ℤ) else 0) :=
    coord_eq_of_vertex_eq D hkx
  have hy : ∀ i, (y.1 i : ℤ) = bcoordZ D i + (if i = c then (1:ℤ) else 0) :=
    coord_eq_of_vertex_eq D hky
  have hx' : ∀ i, (x.1 i : ℤ) = bcoordZ D' i + (if i = a' then (1:ℤ) else 0) :=
    coord_eq_of_vertex_eq D' hk'x
  have hy' : ∀ i, (y.1 i : ℤ) = bcoordZ D' i + (if i = c' then (1:ℤ) else 0) :=
    coord_eq_of_vertex_eq D' hk'y
  -- (x - y) difference pattern in both data
  have key : ∀ i, (if i = a then (1:ℤ) else 0) - (if i = c then (1:ℤ) else 0)
      = (if i = a' then (1:ℤ) else 0) - (if i = c' then (1:ℤ) else 0) := by
    intro i
    have e1 := hx i; have e2 := hy i; have e3 := hx' i; have e4 := hy' i
    -- bcoordZ D i cancels between e1,e2 ; bcoordZ D' i between e3,e4
    have : (x.1 i : ℤ) - (y.1 i : ℤ)
        = (if i = a then (1:ℤ) else 0) - (if i = c then (1:ℤ) else 0) := by
      rw [e1, e2]; ring
    have hh : (x.1 i : ℤ) - (y.1 i : ℤ)
        = (if i = a' then (1:ℤ) else 0) - (if i = c' then (1:ℤ) else 0) := by
      rw [e3, e4]; ring
    rw [← this, hh]
  -- a = a'
  have haa' : a = a' := by
    by_contra h
    have hk := key a
    rw [if_pos rfl, if_neg hac, if_neg h] at hk
    split_ifs at hk <;> omega
  -- bcoordZ D = bcoordZ D'
  have hbc : ∀ i, bcoordZ D i = bcoordZ D' i := by
    intro i
    have e1 := hx i; have e3 := hx' i
    rw [haa'] at e1
    -- e1 : x i = bcoordZ D i + [i = a'], e3 : x i = bcoordZ D' i + [i = a']
    have := e1.symm.trans e3
    linarith [this]
  -- conclude S = S'
  apply Finset.Subset.antisymm
  · intro z hz
    obtain ⟨k, hk⟩ := (mem_iff_exists_vertex hD z).mp hz
    refine (mem_iff_exists_vertex hD' z).mpr ⟨D'.perm.symm (D.perm k), ?_⟩
    have hperm : D'.perm (D'.perm.symm (D.perm k)) = D.perm k := by
      simp
    apply Subtype.ext; funext i
    apply Nat.cast_injective (R := ℤ)
    rw [show ((D'.vertex (D'.perm.symm (D.perm k))).1 i : ℤ)
          = bcoordZ D' i + (if i = D.perm k then (1:ℤ) else 0) from by
        rw [vertex_coord_eq_bcoordZ]; rw [hperm]]
    rw [← hbc, ← vertex_coord_eq_bcoordZ D k i, hk]
  · intro z hz
    obtain ⟨k, hk⟩ := (mem_iff_exists_vertex hD' z).mp hz
    refine (mem_iff_exists_vertex hD z).mpr ⟨D.perm.symm (D'.perm k), ?_⟩
    have hperm : D.perm (D.perm.symm (D'.perm k)) = D'.perm k := by
      simp
    apply Subtype.ext; funext i
    apply Nat.cast_injective (R := ℤ)
    rw [show ((D.vertex (D.perm.symm (D'.perm k))).1 i : ℤ)
          = bcoordZ D i + (if i = D'.perm k then (1:ℤ) else 0) from by
        rw [vertex_coord_eq_bcoordZ]; rw [hperm]]
    rw [hbc, ← vertex_coord_eq_bcoordZ D' k i, hk]

/-- Two distinct vertices of a small simplex differ by a single unit transfer:
their coordinate difference is `e_a - e_c` for distinct coords `a ≠ c`. -/
theorem small_simplex_vertices_differ {d N : ℕ}
    {S : Finset (SimplexGrid d N)} (hS : IsGridSmallSimplex S)
    {x y : SimplexGrid d N} (hxS : x ∈ S) (hyS : y ∈ S) (hxy : x ≠ y) :
    ∃ a c : Fin (d + 1), a ≠ c ∧
      ∀ i, (x.1 i : ℤ) - (y.1 i : ℤ)
        = (if i = a then (1:ℤ) else 0) - (if i = c then (1:ℤ) else 0) := by
  classical
  obtain ⟨D, hD⟩ := hS.2.2
  obtain ⟨kx, hkx⟩ := (mem_iff_exists_vertex hD x).mp hxS
  obtain ⟨ky, hky⟩ := (mem_iff_exists_vertex hD y).mp hyS
  refine ⟨D.perm kx, D.perm ky, ?_, ?_⟩
  · intro h
    apply hxy
    rw [← hkx, ← hky, D.perm.injective h]
  · intro i
    rw [coord_eq_of_vertex_eq D hkx i, coord_eq_of_vertex_eq D hky i]; ring

theorem GeometricGridFacet.completingOppositeVertices_card_le_two {d N : ℕ}
    (F : GeometricGridFacet d N) :
    F.completingOppositeVertices.card ≤ 2 := by
  classical
  have hFcard : F.vertices.card = d := by
    have := F.card_add_one_eq_cell_card; omega
  rcases Nat.lt_or_ge d 2 with hd | hd
  · interval_cases d
    · -- d = 0 : ambient subsingleton
      have hsub : ∀ a b : SimplexGrid 0 N, a = b := by
        intro a b
        apply Subtype.ext; funext i
        have ha := a.2; have hb := b.2
        rw [Fin.sum_univ_one] at ha hb
        rw [Fin.fin_one_eq_zero i]; omega
      have hle : F.completingOppositeVertices.card ≤ 1 :=
        Finset.card_le_one.mpr (fun a _ b _ => hsub a b)
      omega
    · -- d = 1 : the first coordinate takes ≤ 2 values
      obtain ⟨z, hz⟩ := Finset.card_eq_one.mp hFcard
      have hbound : F.completingOppositeVertices.card
          ≤ ({z.1 0 - 1, z.1 0 + 1} : Finset ℕ).card := by
        apply Finset.card_le_card_of_injOn (fun v => v.1 0)
        · intro v hv
          have hSv : IsGridSmallSimplex (insert v F.vertices) :=
            (F.mem_completingOppositeVertices_iff v).mp hv
          have hvnot : v ∉ F.vertices := F.completingVertex_not_mem v hv
          have hvz : v ≠ z := by
            intro h; apply hvnot; rw [h, hz]; exact Finset.mem_singleton_self z
          have hvmem : v ∈ insert v F.vertices := Finset.mem_insert_self _ _
          have hzmem : z ∈ insert v F.vertices := by
            apply Finset.mem_insert_of_mem; rw [hz]; exact Finset.mem_singleton_self z
          obtain ⟨a, c, hac, hdiff⟩ :=
            small_simplex_vertices_differ hSv hvmem hzmem hvz
          have h0 := hdiff 0
          have hdisj : (v.1 0 : ℤ) = (z.1 0 : ℤ) + 1 ∨ (v.1 0 : ℤ) = (z.1 0 : ℤ) - 1 := by
            by_cases h0a : (0 : Fin (1 + 1)) = a
            · rw [if_pos h0a, if_neg (fun h => hac (h0a.symm.trans h))] at h0
              left; omega
            · by_cases h0c : (0 : Fin (1 + 1)) = c
              · rw [if_neg h0a, if_pos h0c] at h0
                right; omega
              · exfalso; apply hac; apply Fin.ext
                have hav : a.val ≠ 0 := fun h => h0a (Fin.ext h.symm)
                have hcv : c.val ≠ 0 := fun h => h0c (Fin.ext h.symm)
                have := a.isLt; have := c.isLt; omega
          clear h0 hdiff
          rcases hdisj with h | h
          · have he : v.1 0 = z.1 0 + 1 := by omega
            simp [he]
          · have he : v.1 0 = z.1 0 - 1 := by omega
            simp [he]
        · intro v _ w _ hvw
          have hvw0 : v.1 0 = w.1 0 := hvw
          have hsv : v.1 0 + v.1 1 = N := by have := v.2; rwa [Fin.sum_univ_two] at this
          have hsw : w.1 0 + w.1 1 = N := by have := w.2; rwa [Fin.sum_univ_two] at this
          have h1 : v.1 1 = w.1 1 := by omega
          apply Subtype.ext; funext i
          fin_cases i
          · exact hvw0
          · exact h1
      have htwo : ({z.1 0 - 1, z.1 0 + 1} : Finset ℕ).card ≤ 2 :=
        (Finset.card_insert_le _ _).trans (by simp)
      omega
  · -- d ≥ 2 : the completion is unique
    have hle : F.completingOppositeVertices.card ≤ 1 := by
      rw [Finset.card_le_one]
      intro v hv w hw
      have hSv : IsGridSmallSimplex (insert v F.vertices) :=
        (F.mem_completingOppositeVertices_iff v).mp hv
      have hSw : IsGridSmallSimplex (insert w F.vertices) :=
        (F.mem_completingOppositeVertices_iff w).mp hw
      have h1lt : 1 < F.vertices.card := by omega
      obtain ⟨p, hp, q, hq, hpq⟩ := Finset.one_lt_card.mp h1lt
      have heq : insert v F.vertices = insert w F.vertices :=
        small_simplex_eq_of_two_common hSv hSw
          (Finset.mem_insert_of_mem hp) (Finset.mem_insert_of_mem hq)
          (Finset.mem_insert_of_mem hp) (Finset.mem_insert_of_mem hq) hpq
      have hvnot : v ∉ F.vertices := F.completingVertex_not_mem v hv
      have hvmem : v ∈ insert w F.vertices := by
        rw [← heq]; exact Finset.mem_insert_self _ _
      rcases Finset.mem_insert.mp hvmem with h | h
      · exact h
      · exact absurd h hvnot
    omega

/-- The canonical local incidence bound, now proved geometrically: every
geometric codimension-one facet has at most two opposite grid vertices. -/
theorem geometricGridOppositeVertexBound {d N : ℕ} :
    GeometricGridOppositeVertexBound d N :=
  GeometricGridOppositeVertexBound.of_completing_bound
    (fun F => F.completingOppositeVertices_card_le_two)

/-- Canonical geometric incidence: every facet is incident to one or two cells. -/
theorem geometricGridIncidenceHypothesis {d N : ℕ} :
    GeometricGridIncidenceHypothesis d N :=
  GeometricGridIncidenceHypothesis.of_oppositeVertexBound
    geometricGridOppositeVertexBound

theorem GeometricGridFacet.interior_incident_card_of_incidence {d N : ℕ}
    (hinc : GeometricGridIncidenceHypothesis d N)
    (F : GeometricGridFacet d N)
    (hF : ¬ F.boundary) :
    F.incidentCells.card = 2 := by
  rcases hinc F with hcard | hcard
  · exact False.elim (hF hcard)
  · exact hcard

/-- The canonical geometric grid certificate from a canonical incidence hypothesis. -/
noncomputable def geometricGridTriangulationCertificate {d N : ℕ}
    (hinc : GeometricGridIncidenceHypothesis d N) :
    Sperner.SpernerTriangulationCertificate
      (SimplexGrid d N) (GeometricGridCell d N) (GeometricGridFacet d N) :=
  { verticesOfCell := fun C => C.vertices
    verticesOfFacet := fun F => F.vertices
    facetsOfCell := fun C => C.facets
    incidentCells := fun F => F.incidentCells
    incident_iff := by
      intro C F
      exact GeometricGridFacet.mem_incidentCells_iff_facets F C
    facet_vertices_subset := by
      intro C F hF
      exact C.facet_vertices_subset F hF
    boundaryFacet := fun F => F.boundary
    boundary_incident_card := by
      intro F hF
      exact F.boundary_incident_card hF
    interior_incident_card := by
      intro F hF
      exact GeometricGridFacet.interior_incident_card_of_incidence hinc F hF }

theorem geometric_grid_local_parity_for_certificate {d N : ℕ}
    (hinc : GeometricGridIncidenceHypothesis d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1))
    (C : GeometricGridCell d N) :
    Odd
      ((Sperner.SpernerTriangulationCertificate.relevantFacetsOfCell
        (geometricGridTriangulationCertificate hinc) L missing C).card)
      ↔
    FullyLabelledGeometricGridCell L C := by
  classical
  simpa [geometricGridTriangulationCertificate,
    Sperner.SpernerTriangulationCertificate.relevantFacetsOfCell,
    Sperner.SpernerTriangulationCertificate.relevantFacet,
    GeometricGridFacet.vertices] using
    GeometricGridCell.localParity C L missing

/--
Canonical geometric grid data sufficient to instantiate the abstract Sperner
certificate over `GeometricGridCell` and `GeometricGridFacet`.
-/
structure GeometricGridSpernerPackageData (d N : ℕ) where
  incidence : GeometricGridIncidenceHypothesis d N
  boundary_odd :
    ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
      GridIsSperner L →
      Odd ((Sperner.SpernerTriangulationCertificate.boundaryRelevantFacets
        (geometricGridTriangulationCertificate incidence) L missing).card)
  local_parity :
    ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1))
      (C : GeometricGridCell d N),
      Odd ((Sperner.SpernerTriangulationCertificate.relevantFacetsOfCell
        (geometricGridTriangulationCertificate incidence) L missing C).card) ↔
        FullyLabelledGeometricGridCell L C
  unit_mesh :
    ∀ C : GeometricGridCell d N,
      ∀ x ∈ C.vertices, ∀ y ∈ C.vertices, ∀ i : Fin (d + 1),
        |((x.1 i : ℤ) - (y.1 i : ℤ))| ≤ 1

/--
The canonical finite grid Sperner data in the shape needed by the Brouwer
route, but with theorem-facing canonical geometric cells.
-/
structure GeometricGridSpernerForBrouwerPackage (d N : ℕ) where
  certificateFacet : Type
  facetFintype : Fintype certificateFacet
  facetDecEq : DecidableEq certificateFacet
  T :
    Sperner.SpernerTriangulationCertificate
      (SimplexGrid d N) (GeometricGridCell d N) certificateFacet
  boundary_odd :
    ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
      GridIsSperner L →
      Odd (T.boundaryRelevantFacets L missing).card
  local_parity :
    ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1))
      (C : GeometricGridCell d N),
      Odd (T.relevantFacetsOfCell L missing C).card ↔
        FullyLabelledGeometricGridCell L C
  unit_mesh :
    ∀ C : GeometricGridCell d N,
      ∀ x ∈ C.vertices, ∀ y ∈ C.vertices, ∀ i : Fin (d + 1),
        |((x.1 i : ℤ) - (y.1 i : ℤ))| ≤ 1

noncomputable def geometricGridSpernerForBrouwerPackage_of_geometricPackageData
    {d N : ℕ}
    (D : GeometricGridSpernerPackageData d N) :
    GeometricGridSpernerForBrouwerPackage d N :=
  { certificateFacet := GeometricGridFacet d N
    facetFintype := inferInstance
    facetDecEq := inferInstance
    T := geometricGridTriangulationCertificate D.incidence
    boundary_odd := D.boundary_odd
    local_parity := D.local_parity
    unit_mesh := D.unit_mesh }

theorem geometric_grid_sperner_for_brouwer_package
    {d N : ℕ}
    (P : GeometricGridSpernerForBrouwerPackage d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (hL : GridIsSperner L)
    (missing : Fin (d + 1)) :
    ∃ C : GeometricGridCell d N,
      FullyLabelledGeometricGridCell L C := by
  classical
  rcases P.T.exists_cell_odd_relevantFacetsOfCell_of_odd_boundary
      L missing (P.boundary_odd L missing hL) with ⟨C, hC⟩
  exact ⟨C, (P.local_parity L missing C).mp hC⟩

theorem geometric_grid_sperner_for_brouwer_package_with_mesh
    {d N : ℕ} [NeZero N]
    (P : GeometricGridSpernerForBrouwerPackage d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (hL : GridIsSperner L)
    (missing : Fin (d + 1)) :
    ∃ C : GeometricGridCell d N,
      FullyLabelledGeometricGridCell L C ∧
        C.MeshLe ((1 : ℝ) / (N : ℝ)) := by
  classical
  rcases geometric_grid_sperner_for_brouwer_package P L hL missing with ⟨C, hC⟩
  refine ⟨C, hC, ?_⟩
  exact C.mesh_le_of_unitMesh (P.unit_mesh C)

theorem geometricGridSpernerPackageData_of_incidence_boundaryOdd {d N : ℕ}
    (hinc : GeometricGridIncidenceHypothesis d N)
    (hboundary :
      ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
        GridIsSperner L →
        Odd ((Sperner.SpernerTriangulationCertificate.boundaryRelevantFacets
          (geometricGridTriangulationCertificate hinc) L missing).card)) :
    GeometricGridSpernerPackageData d N := by
  classical
  refine
    { incidence := hinc
      boundary_odd := hboundary
      local_parity := ?_
      unit_mesh := ?_ }
  · exact geometric_grid_local_parity_for_certificate hinc
  · exact GeometricGridCell.unitMesh

theorem geometricGridSpernerPackageData_of_oppositeVertexBound_boundaryOdd
    {d N : ℕ}
    (hbound : GeometricGridOppositeVertexBound d N)
    (hboundary :
      ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
        GridIsSperner L →
        Odd
          ((Sperner.SpernerTriangulationCertificate.boundaryRelevantFacets
            (geometricGridTriangulationCertificate
              (GeometricGridIncidenceHypothesis.of_oppositeVertexBound hbound))
            L missing).card)) :
    GeometricGridSpernerPackageData d N := by
  classical
  exact geometricGridSpernerPackageData_of_incidence_boundaryOdd
    (GeometricGridIncidenceHypothesis.of_oppositeVertexBound hbound)
    hboundary

noncomputable def geometricGridSpernerForBrouwerPackage_of_oppositeVertexBound_boundaryOdd
    {d N : ℕ}
    (hbound : GeometricGridOppositeVertexBound d N)
    (hboundary :
      ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
        GridIsSperner L →
        Odd
          ((Sperner.SpernerTriangulationCertificate.boundaryRelevantFacets
            (geometricGridTriangulationCertificate
              (GeometricGridIncidenceHypothesis.of_oppositeVertexBound hbound))
            L missing).card)) :
    GeometricGridSpernerForBrouwerPackage d N :=
  geometricGridSpernerForBrouwerPackage_of_geometricPackageData
    (geometricGridSpernerPackageData_of_oppositeVertexBound_boundaryOdd
      hbound hboundary)

/--
Canonical package data from boundary oddness alone. Incidence is now supplied
automatically by `geometricGridIncidenceHypothesis`, so the only remaining input
is boundary oddness for `GridIsSperner`.
-/
theorem geometricGridSpernerPackageData_of_boundaryOdd {d N : ℕ}
    (hboundary :
      ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
        GridIsSperner L →
        Odd
          ((Sperner.SpernerTriangulationCertificate.boundaryRelevantFacets
            (geometricGridTriangulationCertificate
              (geometricGridIncidenceHypothesis (d := d) (N := N)))
            L missing).card)) :
    GeometricGridSpernerPackageData d N := by
  classical
  exact geometricGridSpernerPackageData_of_incidence_boundaryOdd
    geometricGridIncidenceHypothesis
    hboundary

/--
Canonical Brouwer-facing package from boundary oddness alone. Incidence is
supplied automatically by `geometricGridIncidenceHypothesis`.
-/
noncomputable def geometricGridSpernerForBrouwerPackage_of_boundaryOdd {d N : ℕ}
    (hboundary :
      ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
        GridIsSperner L →
        Odd
          ((Sperner.SpernerTriangulationCertificate.boundaryRelevantFacets
            (geometricGridTriangulationCertificate
              (geometricGridIncidenceHypothesis (d := d) (N := N)))
            L missing).card)) :
    GeometricGridSpernerForBrouwerPackage d N :=
  geometricGridSpernerForBrouwerPackage_of_geometricPackageData
    (geometricGridSpernerPackageData_of_boundaryOdd hboundary)

/-
Canonical grid package status:
- unit mesh: proved;
- local parity: proved;
- incidence: proved via `geometricGridIncidenceHypothesis`;
- remaining input for `GeometricGridSpernerForBrouwerPackage d N`:
  boundary oddness only.

The abstract step-chain completion route is not used: bare `ConsecutiveGridStep`
chains have spurious completions that are not small simplices.

The older `GridSpernerPackageData` below is kept only for compatibility with the
existing Brouwer-facing API until that API is migrated to `GeometricGridCell`.
-/

/--
A geometric codimension-one facet: a vertex subset obtained by deleting one
vertex from some geometric small simplex.
-/
abbrev GridSmallFacet (d N : ℕ) :=
  {F : Finset (SimplexGrid d N) //
    ∃ C : GridSmallSimplex d N,
      F ⊆ C.vertices ∧ F.card + 1 = C.vertices.card}

namespace GridSmallFacet

def vertices {d N : ℕ} (F : GridSmallFacet d N) :
    Finset (SimplexGrid d N) :=
  F.1

end GridSmallFacet

namespace GridSmallSimplex

/--
The vertex set of a lower-dimensional geometric small simplex embedded into
the boundary face of the successor-dimensional grid.
-/
noncomputable def extendBoundaryVerticesSucc {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (C : GridSmallSimplex d N) :
    Finset (SimplexGrid (d + 1) N) :=
  C.vertices.image (SimplexGrid.extendBoundarySucc missing)

theorem mem_extendBoundaryVerticesSucc_iff {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (C : GridSmallSimplex d N)
    (x : SimplexGrid (d + 1) N) :
    x ∈ C.extendBoundaryVerticesSucc missing ↔
      ∃ y ∈ C.vertices,
        SimplexGrid.extendBoundarySucc missing y = x := by
  classical
  simp [extendBoundaryVerticesSucc]

theorem extendBoundaryVerticesSucc_onBoundary {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (C : GridSmallSimplex d N)
    {x : SimplexGrid (d + 1) N}
    (hx : x ∈ C.extendBoundaryVerticesSucc missing) :
    SimplexGrid.onBoundaryFace missing x := by
  classical
  rcases (C.mem_extendBoundaryVerticesSucc_iff missing x).mp hx with
    ⟨y, _hy, rfl⟩
  exact SimplexGrid.extendBoundarySucc_onBoundaryFace missing y

theorem extendBoundaryVerticesSucc_card {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (C : GridSmallSimplex d N) :
    (C.extendBoundaryVerticesSucc missing).card = C.vertices.card := by
  classical
  rw [extendBoundaryVerticesSucc]
  exact Finset.card_image_of_injective _ (by
    intro x y hxy
    have hsub :
        (SimplexGrid.boundaryFaceEquivSucc missing).symm x =
          (SimplexGrid.boundaryFaceEquivSucc missing).symm y := by
      apply Subtype.ext
      exact hxy
    exact (SimplexGrid.boundaryFaceEquivSucc missing).symm.injective hsub)

end GridSmallSimplex

/--
A raw vertex-set predicate for boundary facets known to arise from a
lower-dimensional geometric small simplex. This deliberately avoids asserting
the ambient-cell construction needed to package the set as a `GridSmallFacet`.
-/
def IsBoundaryFacetVertexSet {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (F : Finset (SimplexGrid (d + 1) N)) : Prop :=
  (∀ x ∈ F, SimplexGrid.onBoundaryFace missing x) ∧
    ∃ C : GridSmallSimplex d N,
      F = C.extendBoundaryVerticesSucc missing

namespace GridSmallSimplex

theorem extendBoundaryVerticesSucc_isBoundaryFacetVertexSet {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (C : GridSmallSimplex d N) :
    IsBoundaryFacetVertexSet missing (C.extendBoundaryVerticesSucc missing) := by
  classical
  exact ⟨fun x hx => C.extendBoundaryVerticesSucc_onBoundary missing hx,
    ⟨C, rfl⟩⟩

end GridSmallSimplex

namespace GridSmallFacet

/--
Restrict an ambient geometric facet whose vertices all lie on a boundary face
to the corresponding lower-dimensional grid vertex set.
-/
noncomputable def restrictBoundaryVerticesSucc {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (F : GridSmallFacet (d + 1) N)
    (hF : ∀ x ∈ F.1, SimplexGrid.onBoundaryFace missing x) :
    Finset (SimplexGrid d N) :=
  F.1.attach.image fun x =>
    SimplexGrid.restrictBoundarySucc missing x.1 (hF x.1 x.2)

theorem mem_restrictBoundaryVerticesSucc_iff {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (F : GridSmallFacet (d + 1) N)
    (hF : ∀ x ∈ F.1, SimplexGrid.onBoundaryFace missing x)
    (y : SimplexGrid d N) :
    y ∈ F.restrictBoundaryVerticesSucc missing hF ↔
      ∃ x : {x : SimplexGrid (d + 1) N // x ∈ F.1},
        SimplexGrid.restrictBoundarySucc missing x.1 (hF x.1 x.2) = y := by
  classical
  simp [restrictBoundaryVerticesSucc]

theorem extend_restrictBoundaryVerticesSucc {d N : ℕ}
    (missing : Fin ((d + 1) + 1))
    (F : GridSmallFacet (d + 1) N)
    (hF : ∀ x ∈ F.1, SimplexGrid.onBoundaryFace missing x) :
    (F.restrictBoundaryVerticesSucc missing hF).image
        (SimplexGrid.extendBoundarySucc missing) =
      F.1 := by
  classical
  ext x
  constructor
  · intro hx
    rcases Finset.mem_image.mp hx with ⟨y, hy, hyx⟩
    rw [GridSmallFacet.mem_restrictBoundaryVerticesSucc_iff] at hy
    rcases hy with ⟨z, hzy⟩
    have hxz : x = z.1 := by
      calc
        x = SimplexGrid.extendBoundarySucc missing y := hyx.symm
        _ = SimplexGrid.extendBoundarySucc missing
              (SimplexGrid.restrictBoundarySucc missing z.1 (hF z.1 z.2)) := by
            rw [hzy]
        _ = z.1 :=
            SimplexGrid.extend_restrictBoundarySucc missing z.1 (hF z.1 z.2)
    rw [hxz]
    exact z.2
  · intro hxF
    refine Finset.mem_image.mpr ⟨
      SimplexGrid.restrictBoundarySucc missing x (hF x hxF), ?_, ?_⟩
    · rw [GridSmallFacet.mem_restrictBoundaryVerticesSucc_iff]
      exact ⟨⟨x, hxF⟩, rfl⟩
    · exact SimplexGrid.extend_restrictBoundarySucc missing x (hF x hxF)

end GridSmallFacet

theorem GridIsSperner.label_ne_missing_of_onBoundaryFace {d N : ℕ}
    {L : SimplexGrid d N → Fin (d + 1)}
    (hL : GridIsSperner L)
    (missing : Fin (d + 1))
    (x : SimplexGrid d N)
    (hx : SimplexGrid.onBoundaryFace missing x) :
    L x ≠ missing := by
  classical
  intro hlabel
  have hpos : 0 < x.1 (L x) := by
    have h := hL x
    simpa [SimplexGrid.support] using h
  rw [hlabel, hx] at hpos
  exact Nat.not_lt_zero _ hpos

/--
Restrict a Sperner labelling on an ambient successor-dimensional grid to the
boundary face opposite `missing`, transporting the non-missing colours to the
lower-dimensional colour type.
-/
noncomputable def restrictBoundaryLabelSucc {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1)) :
    SimplexGrid d N → Fin (d + 1) :=
  fun y =>
    BoundaryIndex.equivFin missing
      ⟨L (SimplexGrid.extendBoundarySucc missing y),
        GridIsSperner.label_ne_missing_of_onBoundaryFace hL missing
          (SimplexGrid.extendBoundarySucc missing y)
          (SimplexGrid.extendBoundarySucc_onBoundaryFace missing y)⟩

theorem restrictBoundaryLabelSucc_spec {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1))
    (y : SimplexGrid d N) :
    (BoundaryIndex.equivFin missing).symm
      (restrictBoundaryLabelSucc L hL missing y)
      =
    ⟨L (SimplexGrid.extendBoundarySucc missing y),
      GridIsSperner.label_ne_missing_of_onBoundaryFace hL missing
        (SimplexGrid.extendBoundarySucc missing y)
        (SimplexGrid.extendBoundarySucc_onBoundaryFace missing y)⟩ := by
  classical
  simp [restrictBoundaryLabelSucc]

theorem restrictBoundaryLabelSucc_isSperner {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1)) :
    GridIsSperner (restrictBoundaryLabelSucc L hL missing) := by
  classical
  intro y
  have hpos :
      0 <
        (SimplexGrid.extendBoundarySucc missing y).1
          (L (SimplexGrid.extendBoundarySucc missing y)) := by
    have h := hL (SimplexGrid.extendBoundarySucc missing y)
    simpa [SimplexGrid.support] using h
  have hne :
      L (SimplexGrid.extendBoundarySucc missing y) ≠ missing :=
    GridIsSperner.label_ne_missing_of_onBoundaryFace hL missing
      (SimplexGrid.extendBoundarySucc missing y)
      (SimplexGrid.extendBoundarySucc_onBoundaryFace missing y)
  have hcoord :
      (SimplexGrid.extendBoundarySucc missing y).1
          (L (SimplexGrid.extendBoundarySucc missing y)) =
        y.1 (BoundaryIndex.equivFin missing
          ⟨L (SimplexGrid.extendBoundarySucc missing y), hne⟩) := by
    exact SimplexGrid.extendBoundarySucc_coord_of_ne missing y hne
  have hypos :
      0 < y.1 (BoundaryIndex.equivFin missing
        ⟨L (SimplexGrid.extendBoundarySucc missing y), hne⟩) := by
    simpa [hcoord] using hpos
  simpa [SimplexGrid.support, restrictBoundaryLabelSucc, hne] using hypos

theorem fullyLabelled_restrictBoundaryLabelSucc_iff_almostFullyLabelled_extend
    {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1))
    (C : GridSmallSimplex d N) :
    FullyLabelledGridSmallSimplex
      (restrictBoundaryLabelSucc L hL missing) C
      ↔
    EcoLean.Sperner.AlmostFullyLabeled
      L missing
      (C.extendBoundaryVerticesSucc missing) := by
  classical
  constructor
  · intro hfull i hi_missing
    rw [EcoLean.Sperner.mem_labelsOn_iff]
    rw [FullyLabelledGridSmallSimplex] at hfull
    rw [EcoLean.Sperner.fullyLabeled_iff
      (restrictBoundaryLabelSucc L hL missing) C.vertices] at hfull
    let bi : BoundaryIndex (d + 1) missing := ⟨i, hi_missing⟩
    have hlabel :=
      hfull (BoundaryIndex.equivFin missing bi)
    rw [EcoLean.Sperner.mem_labelsOn_iff] at hlabel
    rcases hlabel with ⟨y, hyC, hylabel⟩
    refine ⟨SimplexGrid.extendBoundarySucc missing y, ?_, ?_⟩
    · rw [GridSmallSimplex.mem_extendBoundaryVerticesSucc_iff]
      exact ⟨y, hyC, rfl⟩
    · have hspec := restrictBoundaryLabelSucc_spec L hL missing y
      have hsub :
          bi =
            (BoundaryIndex.equivFin missing).symm
              (restrictBoundaryLabelSucc L hL missing y) := by
        rw [hylabel]
        exact (Equiv.symm_apply_apply (BoundaryIndex.equivFin missing) bi).symm
      have hbi :
          bi =
            ⟨L (SimplexGrid.extendBoundarySucc missing y),
              GridIsSperner.label_ne_missing_of_onBoundaryFace hL missing
                (SimplexGrid.extendBoundarySucc missing y)
                (SimplexGrid.extendBoundarySucc_onBoundaryFace missing y)⟩ := by
        rw [hsub, hspec]
      exact (congrArg Subtype.val hbi).symm
  · intro halmost
    rw [FullyLabelledGridSmallSimplex, EcoLean.Sperner.fullyLabeled_iff]
    intro j
    rw [EcoLean.Sperner.mem_labelsOn_iff]
    let bi : BoundaryIndex (d + 1) missing :=
      (BoundaryIndex.equivFin missing).symm j
    have hlabel := halmost bi.1 bi.2
    rw [EcoLean.Sperner.mem_labelsOn_iff] at hlabel
    rcases hlabel with ⟨x, hxExt, hxlabel⟩
    rw [GridSmallSimplex.mem_extendBoundaryVerticesSucc_iff] at hxExt
    rcases hxExt with ⟨y, hyC, hyx⟩
    refine ⟨y, hyC, ?_⟩
    subst hyx
    have hspec := restrictBoundaryLabelSucc_spec L hL missing y
    have hsub :
        (BoundaryIndex.equivFin missing).symm
            (restrictBoundaryLabelSucc L hL missing y) = bi := by
      rw [hspec]
      apply Subtype.ext
      exact hxlabel
    have h := congrArg (BoundaryIndex.equivFin missing) hsub
    simpa [bi] using h

/--
Lower-dimensional small simplices that are fully labelled by the boundary
restriction of an ambient Sperner labelling.
-/
noncomputable def LowerFullyLabelledBoundaryCells {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1)) :
    Finset (GridSmallSimplex d N) := by
  classical
  exact Finset.univ.filter fun C =>
    FullyLabelledGridSmallSimplex
      (restrictBoundaryLabelSucc L hL missing) C

theorem mem_LowerFullyLabelledBoundaryCells_iff {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1))
    (C : GridSmallSimplex d N) :
    C ∈ LowerFullyLabelledBoundaryCells L hL missing ↔
      FullyLabelledGridSmallSimplex
        (restrictBoundaryLabelSucc L hL missing) C := by
  classical
  simp [LowerFullyLabelledBoundaryCells]

theorem GridSmallSimplex.extendBoundaryVerticesSucc_injective {d N : ℕ}
    (missing : Fin ((d + 1) + 1)) :
    Function.Injective
      (fun C : GridSmallSimplex d N =>
        C.extendBoundaryVerticesSucc missing) := by
  classical
  intro C₁ C₂ hC
  apply Subtype.ext
  ext y
  constructor
  · intro hy
    have hyExt :
        SimplexGrid.extendBoundarySucc missing y ∈
          C₁.extendBoundaryVerticesSucc missing := by
      rw [GridSmallSimplex.mem_extendBoundaryVerticesSucc_iff]
      exact ⟨y, hy, rfl⟩
    have hC' :
        C₁.extendBoundaryVerticesSucc missing =
          C₂.extendBoundaryVerticesSucc missing := hC
    have hyExt₂ :
        SimplexGrid.extendBoundarySucc missing y ∈
          C₂.extendBoundaryVerticesSucc missing := by
      rw [← hC']
      exact hyExt
    rcases (C₂.mem_extendBoundaryVerticesSucc_iff missing
        (SimplexGrid.extendBoundarySucc missing y)).mp hyExt₂ with
      ⟨z, hz, hzy⟩
    have hsub :
        (SimplexGrid.boundaryFaceEquivSucc missing).symm z =
          (SimplexGrid.boundaryFaceEquivSucc missing).symm y := by
      apply Subtype.ext
      exact hzy
    have hzy' : z = y :=
      (SimplexGrid.boundaryFaceEquivSucc missing).symm.injective hsub
    simpa [hzy'] using hz
  · intro hy
    have hyExt :
        SimplexGrid.extendBoundarySucc missing y ∈
          C₂.extendBoundaryVerticesSucc missing := by
      rw [GridSmallSimplex.mem_extendBoundaryVerticesSucc_iff]
      exact ⟨y, hy, rfl⟩
    have hC' :
        C₁.extendBoundaryVerticesSucc missing =
          C₂.extendBoundaryVerticesSucc missing := hC
    have hyExt₁ :
        SimplexGrid.extendBoundarySucc missing y ∈
          C₁.extendBoundaryVerticesSucc missing := by
      rw [hC']
      exact hyExt
    rcases (C₁.mem_extendBoundaryVerticesSucc_iff missing
        (SimplexGrid.extendBoundarySucc missing y)).mp hyExt₁ with
      ⟨z, hz, hzy⟩
    have hsub :
        (SimplexGrid.boundaryFaceEquivSucc missing).symm z =
          (SimplexGrid.boundaryFaceEquivSucc missing).symm y := by
      apply Subtype.ext
      exact hzy
    have hzy' : z = y :=
      (SimplexGrid.boundaryFaceEquivSucc missing).symm.injective hsub
    simpa [hzy'] using hz

/--
The raw ambient boundary vertex sets obtained from fully labelled
lower-dimensional cells.
-/
noncomputable def LowerFullyLabelledBoundaryVertexSets {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1)) :
    Finset (Finset (SimplexGrid (d + 1) N)) :=
  (LowerFullyLabelledBoundaryCells L hL missing).image fun C =>
    C.extendBoundaryVerticesSucc missing

theorem LowerFullyLabelledBoundaryVertexSets_card {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1)) :
    (LowerFullyLabelledBoundaryVertexSets L hL missing).card =
      (LowerFullyLabelledBoundaryCells L hL missing).card := by
  classical
  rw [LowerFullyLabelledBoundaryVertexSets]
  exact Finset.card_image_of_injective _
    (GridSmallSimplex.extendBoundaryVerticesSucc_injective missing)

theorem mem_LowerFullyLabelledBoundaryVertexSets_iff {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1))
    (S : Finset (SimplexGrid (d + 1) N)) :
    S ∈ LowerFullyLabelledBoundaryVertexSets L hL missing ↔
      ∃ C : GridSmallSimplex d N,
        FullyLabelledGridSmallSimplex
          (restrictBoundaryLabelSucc L hL missing) C ∧
        C.extendBoundaryVerticesSucc missing = S := by
  classical
  constructor
  · intro hS
    rcases Finset.mem_image.mp hS with ⟨C, hC, hCS⟩
    rw [mem_LowerFullyLabelledBoundaryCells_iff] at hC
    exact ⟨C, hC, hCS⟩
  · intro hS
    rcases hS with ⟨C, hC, hCS⟩
    refine Finset.mem_image.mpr ⟨C, ?_, hCS⟩
    rw [mem_LowerFullyLabelledBoundaryCells_iff]
    exact hC

theorem lowerFullyLabelledBoundaryVertexSet_almostFullyLabelled {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1))
    {S : Finset (SimplexGrid (d + 1) N)}
    (hS : S ∈ LowerFullyLabelledBoundaryVertexSets L hL missing) :
    EcoLean.Sperner.AlmostFullyLabeled L missing S := by
  classical
  rcases (mem_LowerFullyLabelledBoundaryVertexSets_iff
      L hL missing S).mp hS with ⟨C, hC, hCS⟩
  rw [← hCS]
  exact (fullyLabelled_restrictBoundaryLabelSucc_iff_almostFullyLabelled_extend
    L hL missing C).mp hC

/-! ### Canonical boundary oddness scaffolding (`GeometricGridFacet`)

The canonical boundary-oddness obligation for the package constructors is

  `Odd ((geometricGridTriangulationCertificate geometricGridIncidenceHypothesis)
          .boundaryRelevantFacets L missing).card`.

Below we expose the boundary-relevant facets in canonical-layer terms and the
target lower-dimensional fully-labelled cells, then isolate the precise
geometric correspondence that remains. Everything here stays on
`GeometricGridCell` / `GeometricGridFacet`; the older `GridSmallSimplex`
correspondence above is not reused. -/

/--
Canonical boundary-relevant facets: boundary `GeometricGridFacet`s whose vertex
set is almost fully labelled (it realizes every label except `missing`). This is
the canonical-layer description of the certificate's `boundaryRelevantFacets`.
-/
noncomputable def GeometricGridBoundaryRelevantFacets {d N : ℕ}
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1)) :
    Finset (GeometricGridFacet d N) := by
  classical
  exact Finset.univ.filter fun F =>
    F.boundary ∧ EcoLean.Sperner.AlmostFullyLabeled L missing F.vertices

theorem mem_GeometricGridBoundaryRelevantFacets_iff {d N : ℕ}
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1))
    (F : GeometricGridFacet d N) :
    F ∈ GeometricGridBoundaryRelevantFacets L missing ↔
      F.boundary ∧ EcoLean.Sperner.AlmostFullyLabeled L missing F.vertices := by
  classical
  simp [GeometricGridBoundaryRelevantFacets]

/-- The canonical boundary-relevant facets are exactly the certificate's. -/
theorem GeometricGridBoundaryRelevantFacets_eq_certificate {d N : ℕ}
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1)) :
    GeometricGridBoundaryRelevantFacets L missing =
      ((geometricGridTriangulationCertificate
        (geometricGridIncidenceHypothesis (d := d) (N := N))).boundaryRelevantFacets
        L missing) := by
  classical
  ext F
  simp [GeometricGridBoundaryRelevantFacets,
    Sperner.SpernerTriangulationCertificate.mem_boundaryRelevantFacets_iff,
    Sperner.SpernerTriangulationCertificate.relevantFacet,
    geometricGridTriangulationCertificate, GeometricGridFacet.vertices]

/--
The lower-dimensional canonical cells that become fully labelled under the
boundary restriction of an ambient Sperner labelling. These are the intended
images of the boundary-relevant facets on the coordinate face `x missing = 0`.
-/
noncomputable def LowerFullyLabelledGeometricBoundaryCells {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1)) :
    Finset (GeometricGridCell d N) := by
  classical
  exact Finset.univ.filter fun C =>
    FullyLabelledGeometricGridCell (restrictBoundaryLabelSucc L hL missing) C

theorem mem_LowerFullyLabelledGeometricBoundaryCells_iff {d N : ℕ}
    (L : SimplexGrid (d + 1) N → Fin ((d + 1) + 1))
    (hL : GridIsSperner L)
    (missing : Fin ((d + 1) + 1))
    (C : GeometricGridCell d N) :
    C ∈ LowerFullyLabelledGeometricBoundaryCells L hL missing ↔
      FullyLabelledGeometricGridCell (restrictBoundaryLabelSucc L hL missing) C := by
  classical
  simp [LowerFullyLabelledGeometricBoundaryCells]

/-! ### Audit: `N = 0`, and the incident-count boundary notion -/

/--
Audit (`N = 0`): there is no Sperner labelling at zero mesh. Every coordinate of
every point of `SimplexGrid d 0` is `0` (the coordinates are naturals summing to
`0`), so the support is empty and no label can point at a positive coordinate.
-/
theorem not_gridIsSperner_zero_mesh {d : ℕ}
    (L : SimplexGrid d 0 → Fin (d + 1)) :
    ¬ GridIsSperner L := by
  classical
  intro hL
  have h := hL ⟨fun _ => 0, by simp⟩
  simp [SimplexGrid.support] at h

/-
`N = 0` audit conclusion:
The boundary-oddness obligation is demanded for all `N`, with no `[NeZero N]`.
This is NOT a false target: at `N = 0` the hypothesis `GridIsSperner L` is
unsatisfiable (`not_gridIsSperner_zero_mesh`), so the implication
`GridIsSperner L → Odd (…)` holds vacuously. No `[NeZero N]` / `0 < N` is needed
on the package constructors for the `N = 0` case.
-/

/--
For `d ≥ 2`, every geometric facet is incident to exactly one geometric cell.
Distinct small simplices share at most one vertex
(`small_simplex_eq_of_two_common`), and a facet has `d ≥ 2` vertices, so it cannot
lie in two distinct cells; with `1 ≤ incidentCells.card` this forces `= 1`.
-/
theorem GeometricGridFacet.boundary_of_two_le_dim {d N : ℕ}
    (hd : 2 ≤ d)
    (F : GeometricGridFacet d N) :
    F.boundary := by
  classical
  have hge := F.one_le_incidentCells_card
  have hle : F.incidentCells.card ≤ 1 := by
    rw [Finset.card_le_one]
    intro C₁ hC₁ C₂ hC₂
    have hF₁ : F ∈ C₁.facets := (F.mem_incidentCells_iff_facets C₁).mp hC₁
    have hF₂ : F ∈ C₂.facets := (F.mem_incidentCells_iff_facets C₂).mp hC₂
    have hsub₁ : F.vertices ⊆ C₁.vertices := C₁.facet_vertices_subset F hF₁
    have hsub₂ : F.vertices ⊆ C₂.vertices := C₂.facet_vertices_subset F hF₂
    have hFcard : F.vertices.card = d := by
      have := F.card_add_one_eq_cell_card; omega
    obtain ⟨p, hp, q, hq, hpq⟩ :=
      Finset.one_lt_card.mp (show 1 < F.vertices.card by omega)
    have hverts : C₁.vertices = C₂.vertices :=
      small_simplex_eq_of_two_common C₁.2 C₂.2
        (hsub₁ hp) (hsub₁ hq) (hsub₂ hp) (hsub₂ hq) hpq
    exact Subtype.ext hverts
  exact le_antisymm hle hge

noncomputable instance instDecidableAlmostFullyLabeledGridSmallFacet {d N : ℕ}
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1)) :
    DecidablePred fun F : GridSmallFacet d N =>
      EcoLean.Sperner.AlmostFullyLabeled L missing F.1 := by
  classical
  intro F
  exact Classical.propDecidable _

namespace BaryFreudenthalDatum

/-- The geometric small facet obtained by deleting the `k`th datum vertex. -/
noncomputable def toGridSmallFacet {d N : ℕ}
    (D : BaryFreudenthalDatum d N)
    (k : Fin (d + 1)) :
    GridSmallFacet d N :=
  ⟨(BaryFreudenthalFacet.mk D.toSimplex k).vertices,
    ⟨D.toGridSmallSimplex, by
      intro x hx
      have hsub :=
        (BaryFreudenthalFacet.mk D.toSimplex k).vertices_subset_simplex_vertices
          hx
      simpa [BaryFreudenthalDatum.toGridSmallSimplex,
        GridSmallSimplex.vertices] using hsub,
      by
        have hmem :
            D.toSimplex.vertex k ∈ D.toSimplex.vertices :=
          (D.toSimplex.mem_vertices_iff (D.toSimplex.vertex k)).mpr
            ⟨k, rfl⟩
        have hcard :
            (D.toSimplex.vertices.erase (D.toSimplex.vertex k)).card + 1 =
              D.toSimplex.vertices.card :=
          Finset.card_erase_add_one hmem
        simpa [BaryFreudenthalDatum.toGridSmallSimplex,
          GridSmallSimplex.vertices,
          BaryFreudenthalSimplex.erase_vertex_eq_deletionFacet_vertices]
          using hcard⟩⟩

theorem toGridSmallFacet_injective {d N : ℕ}
    (D : BaryFreudenthalDatum d N) :
    Function.Injective D.toGridSmallFacet := by
  classical
  intro k l hkl
  have hverts :
      (BaryFreudenthalFacet.mk D.toSimplex k).vertices =
        (BaryFreudenthalFacet.mk D.toSimplex l).vertices := by
    exact congrArg Subtype.val hkl
  exact (BaryFreudenthalSimplex.deletionFacet_vertices_eq_iff
    D.toSimplex k l).mp hverts

end BaryFreudenthalDatum

noncomputable instance instGridSmallFacetDecidableEq (d N : ℕ) :
    DecidableEq (GridSmallFacet d N) :=
  Classical.decEq _

noncomputable instance instGridSmallFacetFintype (d N : ℕ) :
    Fintype (GridSmallFacet d N) :=
  Fintype.ofFinite _

namespace GridSmallSimplex

/-- The geometric codimension-one facets of a geometric small simplex. -/
noncomputable def facets {d N : ℕ}
    (C : GridSmallSimplex d N) :
    Finset (GridSmallFacet d N) :=
  C.vertices.attach.image fun x =>
    ⟨C.vertices.erase x.1,
      ⟨C, Finset.erase_subset x.1 C.vertices,
        Finset.card_erase_add_one x.2⟩⟩

theorem mem_facets_iff {d N : ℕ}
    (C : GridSmallSimplex d N)
    (F : GridSmallFacet d N) :
    F ∈ C.facets ↔
      ∃ x ∈ C.vertices, F.1 = C.vertices.erase x := by
  classical
  constructor
  · intro hF
    rcases Finset.mem_image.mp hF with ⟨x, _hx, hFx⟩
    refine ⟨x.1, x.2, ?_⟩
    exact (congrArg Subtype.val hFx).symm
  · intro hF
    rcases hF with ⟨x, hx, hFx⟩
    refine Finset.mem_image.mpr ⟨⟨x, hx⟩, by simp, ?_⟩
    apply Subtype.ext
    exact hFx.symm

theorem facet_vertices_subset {d N : ℕ}
    (C : GridSmallSimplex d N)
    (F : GridSmallFacet d N)
    (hF : F ∈ C.facets) :
    F.vertices ⊆ C.vertices := by
  classical
  rw [mem_facets_iff] at hF
  rcases hF with ⟨x, _hx, hFx⟩
  intro y hy
  change y ∈ F.1 at hy
  rw [hFx] at hy
  exact Finset.mem_of_mem_erase hy

end GridSmallSimplex

namespace BaryFreudenthalDatum

theorem facets_toGridSmallSimplex {d N : ℕ}
    (D : BaryFreudenthalDatum d N) :
    D.toGridSmallSimplex.facets =
      (Finset.univ : Finset (Fin (d + 1))).image D.toGridSmallFacet := by
  classical
  ext F
  rw [GridSmallSimplex.mem_facets_iff]
  constructor
  · intro hF
    rcases hF with ⟨x, hx, hFx⟩
    have hx' : x ∈ D.toSimplex.vertices := by
      simpa [BaryFreudenthalDatum.toGridSmallSimplex,
        GridSmallSimplex.vertices] using hx
    rcases (D.toSimplex.mem_vertices_iff x).mp hx' with ⟨k, hkx⟩
    refine Finset.mem_image.mpr ⟨k, Finset.mem_univ k, ?_⟩
    apply Subtype.ext
    calc
      (D.toGridSmallFacet k).1 =
          (BaryFreudenthalFacet.mk D.toSimplex k).vertices := rfl
      _ = D.toSimplex.vertices.erase (D.toSimplex.vertex k) :=
          (BaryFreudenthalSimplex.erase_vertex_eq_deletionFacet_vertices
            D.toSimplex k).symm
      _ = D.toGridSmallSimplex.vertices.erase x := by
          rw [hkx]
          rfl
      _ = F.1 := hFx.symm
  · intro hF
    rcases Finset.mem_image.mp hF with ⟨k, _hk, hkF⟩
    refine ⟨D.toSimplex.vertex k, ?_, ?_⟩
    · simpa [BaryFreudenthalDatum.toGridSmallSimplex,
        GridSmallSimplex.vertices] using
        (D.toSimplex.mem_vertices_iff (D.toSimplex.vertex k)).mpr
          ⟨k, rfl⟩
    · have hval := congrArg Subtype.val hkF
      calc
        F.1 = (D.toGridSmallFacet k).1 := hval.symm
        _ = (BaryFreudenthalFacet.mk D.toSimplex k).vertices := rfl
        _ = D.toGridSmallSimplex.vertices.erase (D.toSimplex.vertex k) := by
          rw [← BaryFreudenthalSimplex.erase_vertex_eq_deletionFacet_vertices]
          rfl

theorem localParity_toGridSmallSimplex {d N : ℕ}
    (D : BaryFreudenthalDatum d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1)) :
    Odd
      ((D.toGridSmallSimplex.facets.filter fun F : GridSmallFacet d N =>
        EcoLean.Sperner.AlmostFullyLabeled L missing F.1).card)
      ↔
    FullyLabelledGridSmallSimplex L D.toGridSmallSimplex := by
  classical
  let C : Coloring d N := { color := L }
  have hfilter :
      ((Finset.univ : Finset (Fin (d + 1))).filter fun k =>
          EcoLean.Sperner.AlmostFullyLabeled L missing
            ((D.toGridSmallFacet k).1))
        =
      D.toSimplex.relevantOmittedIndices C missing := by
    ext k
    rw [BaryFreudenthalSimplex.mem_relevantOmittedIndices_iff]
    simp [C, BaryFreudenthalDatum.toGridSmallFacet]
  calc
    Odd
      ((D.toGridSmallSimplex.facets.filter fun F : GridSmallFacet d N =>
        EcoLean.Sperner.AlmostFullyLabeled L missing F.1).card)
        ↔
      Odd (D.toSimplex.relevantOmittedIndices C missing).card := by
        rw [D.facets_toGridSmallSimplex]
        rw [Finset.filter_image]
        rw [hfilter]
        rw [Finset.card_image_of_injective _ D.toGridSmallFacet_injective]
    _ ↔ IsFullyColored C D.toSimplex :=
      D.toSimplex.local_parity C missing
    _ ↔ FullyLabelledGridSmallSimplex L D.toGridSmallSimplex := by
      simp [IsFullyColored, FullyLabelledGridSmallSimplex, C,
        BaryFreudenthalDatum.toGridSmallSimplex, GridSmallSimplex.vertices]

end BaryFreudenthalDatum

namespace GridSmallFacet

/-- Geometric cells incident to a geometric facet. -/
noncomputable def incidentCells {d N : ℕ}
    (F : GridSmallFacet d N) :
    Finset (GridSmallSimplex d N) :=
  (allGridSmallSimplices d N).filter fun C =>
    F ∈ C.facets

theorem mem_incidentCells_iff {d N : ℕ}
    (F : GridSmallFacet d N)
    (C : GridSmallSimplex d N) :
    C ∈ F.incidentCells ↔ F ∈ C.facets := by
  classical
  simp [incidentCells, mem_allGridSmallSimplices]

/-- A geometric facet is on the boundary when it has exactly one incident cell. -/
def boundary {d N : ℕ}
    (F : GridSmallFacet d N) : Prop :=
  F.incidentCells.card = 1

theorem boundary_incident_card {d N : ℕ}
    (F : GridSmallFacet d N)
    (hF : F.boundary) :
    F.incidentCells.card = 1 :=
  hF

end GridSmallFacet

/--
Boundary facets relevant to `missing`, written directly in terms of geometric
grid facets rather than through a triangulation certificate.
-/
noncomputable def GridBoundaryRelevantFacets {d N : ℕ}
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1)) :
    Finset (GridSmallFacet d N) := by
  classical
  exact Finset.univ.filter fun F : GridSmallFacet d N =>
    F.boundary ∧
      EcoLean.Sperner.AlmostFullyLabeled L missing F.1

namespace GridSmallSimplex

theorem localParity {d N : ℕ}
    (C : GridSmallSimplex d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1)) :
    Odd
      ((C.facets.filter fun F : GridSmallFacet d N =>
        EcoLean.Sperner.AlmostFullyLabeled L missing F.1).card)
      ↔
    FullyLabelledGridSmallSimplex L C := by
  classical
  rcases C.2 with ⟨D, hD⟩
  have hC : C = D.toGridSmallSimplex := by
    apply Subtype.ext
    exact hD.symm
  rw [hC]
  exact BaryFreudenthalDatum.localParity_toGridSmallSimplex D L missing

end GridSmallSimplex

theorem grid_local_parity {d N : ℕ} :
    ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1))
      (C : GridSmallSimplex d N),
      Odd ((C.facets.filter fun F : GridSmallFacet d N =>
        EcoLean.Sperner.AlmostFullyLabeled L missing F.1).card)
        ↔ FullyLabelledGridSmallSimplex L C := by
  intro L missing C
  exact GridSmallSimplex.localParity C L missing

/-- The geometric incidence property needed by the grid Sperner certificate. -/
def GridSmallSimplexIncidenceHypothesis (d N : ℕ) : Prop :=
  ∀ F : GridSmallFacet d N,
    F.incidentCells.card = 1 ∨ F.incidentCells.card = 2

theorem GridSmallFacet.interior_incident_card_of_incidence {d N : ℕ}
    (hinc : GridSmallSimplexIncidenceHypothesis d N)
    (F : GridSmallFacet d N)
    (hF : ¬ F.boundary) :
    F.incidentCells.card = 2 := by
  rcases hinc F with hcard | hcard
  · exact False.elim (hF hcard)
  · exact hcard

/-- The geometric grid-small-simplex certificate from an incidence hypothesis. -/
noncomputable def gridSmallTriangulationCertificate {d N : ℕ}
    (hinc : GridSmallSimplexIncidenceHypothesis d N) :
    Sperner.SpernerTriangulationCertificate
      (SimplexGrid d N) (GridSmallSimplex d N) (GridSmallFacet d N) :=
  { verticesOfCell := fun C => C.vertices
    verticesOfFacet := fun F => F.vertices
    facetsOfCell := fun C => C.facets
    incidentCells := fun F => F.incidentCells
    incident_iff := by
      intro C F
      exact GridSmallFacet.mem_incidentCells_iff F C
    facet_vertices_subset := by
      intro C F hF
      exact C.facet_vertices_subset F hF
    boundaryFacet := fun F => F.boundary
    boundary_incident_card := by
      intro F hF
      exact F.boundary_incident_card hF
    interior_incident_card := by
      intro F hF
      exact GridSmallFacet.interior_incident_card_of_incidence hinc F hF }

theorem GridBoundaryRelevantFacets_eq_certificate {d N : ℕ}
    (hinc : GridSmallSimplexIncidenceHypothesis d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1)) :
    GridBoundaryRelevantFacets L missing =
      (gridSmallTriangulationCertificate hinc).boundaryRelevantFacets
        L missing := by
  classical
  ext F
  simp [GridBoundaryRelevantFacets, gridSmallTriangulationCertificate,
    Sperner.SpernerTriangulationCertificate.boundaryRelevantFacets,
    Sperner.SpernerTriangulationCertificate.relevantFacet,
    GridSmallFacet.vertices]

/-
Future boundary-oddness target:

theorem grid_boundary_odd
    {d N : ℕ}
    (hinc : GridSmallSimplexIncidenceHypothesis d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1))
    (hL : GridIsSperner L) :
    Odd (((gridSmallTriangulationCertificate hinc).boundaryRelevantFacets
      L missing).card)

Equivalently, by `GridBoundaryRelevantFacets_eq_certificate`, prove
`Odd (GridBoundaryRelevantFacets L missing).card`.
-/

theorem grid_local_parity_for_certificate {d N : ℕ}
    (hinc : GridSmallSimplexIncidenceHypothesis d N) :
    ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1))
      (C : GridSmallSimplex d N),
      Odd (((gridSmallTriangulationCertificate hinc).relevantFacetsOfCell
        L missing C).card) ↔
        FullyLabelledGridSmallSimplex L C := by
  classical
  intro L missing C
  simpa [gridSmallTriangulationCertificate,
    Sperner.SpernerTriangulationCertificate.relevantFacetsOfCell,
    Sperner.SpernerTriangulationCertificate.relevantFacet,
    GridSmallFacet.vertices] using
    GridSmallSimplex.localParity C L missing

/--
Geometric grid data sufficient to instantiate the Brouwer-facing finite
Sperner package.
-/
structure GridSpernerPackageData (d N : ℕ) where
  incidence : GridSmallSimplexIncidenceHypothesis d N
  boundary_odd :
    ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
      GridIsSperner L →
      Odd (((gridSmallTriangulationCertificate incidence).boundaryRelevantFacets
        L missing).card)
  local_parity :
    ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1))
      (C : GridSmallSimplex d N),
      Odd (((gridSmallTriangulationCertificate incidence).relevantFacetsOfCell
        L missing C).card) ↔
        FullyLabelledGridSmallSimplex L C
  unit_mesh :
    ∀ C : GridSmallSimplex d N,
      GridSmallSimplexHasUnitCoordinateMesh C

theorem grid_sperner_for_brouwer_from_certificate
    {d N : ℕ} {Facet : Type*}
    (T : Sperner.SpernerTriangulationCertificate
      (SimplexGrid d N) (GridSmallSimplex d N) Facet)
    (L : SimplexGrid d N → Fin (d + 1))
    (missing : Fin (d + 1))
    (hSperner : GridIsSperner L)
    (boundary_odd :
      Odd (T.boundaryRelevantFacets L missing).card)
    (local_parity :
      ∀ C : GridSmallSimplex d N,
        Odd (T.relevantFacetsOfCell L missing C).card ↔
          FullyLabelledGridSmallSimplex L C) :
    ∃ C : GridSmallSimplex d N,
      FullyLabelledGridSmallSimplex L C := by
  classical
  have _hSperner := hSperner
  rcases T.exists_cell_odd_relevantFacetsOfCell_of_odd_boundary
      L missing boundary_odd with ⟨C, hC⟩
  exact ⟨C, (local_parity C).mp hC⟩

/--
The finite grid Sperner data needed later for Brouwer, phrased over geometric
small simplices in the barycentric grid.
-/
structure GridSpernerForBrouwerPackage (d N : ℕ) where
  certificateFacet : Type
  facetFintype : Fintype certificateFacet
  facetDecEq : DecidableEq certificateFacet
  T :
    Sperner.SpernerTriangulationCertificate
      (SimplexGrid d N) (GridSmallSimplex d N) certificateFacet
  boundary_odd :
    ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
      GridIsSperner L →
      Odd (T.boundaryRelevantFacets L missing).card
  local_parity :
    ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1))
      (C : GridSmallSimplex d N),
      Odd (T.relevantFacetsOfCell L missing C).card ↔
        FullyLabelledGridSmallSimplex L C
  unit_mesh :
    ∀ C : GridSmallSimplex d N,
      GridSmallSimplexHasUnitCoordinateMesh C

/-- Convert geometric grid package data into the Brouwer-facing package. -/
noncomputable def gridSpernerForBrouwerPackage_of_gridPackageData {d N : ℕ}
    (D : GridSpernerPackageData d N) :
    GridSpernerForBrouwerPackage d N :=
  { certificateFacet := GridSmallFacet d N
    facetFintype := inferInstance
    facetDecEq := inferInstance
    T := gridSmallTriangulationCertificate D.incidence
    boundary_odd := D.boundary_odd
    local_parity := D.local_parity
    unit_mesh := D.unit_mesh }

/--
Build the geometric grid package data from exactly the two remaining
geometric/combinatorial inputs: facet incidence and boundary oddness.

The local parity and unit mesh fields are already provided by
`grid_local_parity_for_certificate` and `grid_unit_mesh`.
-/
theorem gridSpernerPackageData_of_incidence_boundaryOdd {d N : ℕ}
    (hinc : GridSmallSimplexIncidenceHypothesis d N)
    (hboundary :
      ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
        GridIsSperner L →
        Odd (((gridSmallTriangulationCertificate hinc).boundaryRelevantFacets
          L missing).card)) :
    GridSpernerPackageData d N := by
  classical
  refine
    { incidence := hinc
      boundary_odd := hboundary
      local_parity := ?_
      unit_mesh := ?_ }
  · exact grid_local_parity_for_certificate hinc
  · exact grid_unit_mesh

/--
Directly construct the Brouwer-facing finite grid package from geometric
incidence plus boundary oddness.
-/
noncomputable def gridSpernerForBrouwerPackage_of_incidence_boundaryOdd {d N : ℕ}
    (hinc : GridSmallSimplexIncidenceHypothesis d N)
    (hboundary :
      ∀ (L : SimplexGrid d N → Fin (d + 1)) (missing : Fin (d + 1)),
        GridIsSperner L →
        Odd (((gridSmallTriangulationCertificate hinc).boundaryRelevantFacets
          L missing).card)) :
    GridSpernerForBrouwerPackage d N :=
  gridSpernerForBrouwerPackage_of_gridPackageData
    (gridSpernerPackageData_of_incidence_boundaryOdd hinc hboundary)

/-
Remaining combinatorial/geometric obligations:

At this point, to obtain `GridSpernerForBrouwerPackage d N`, it remains only
to prove:

1. `GridSmallSimplexIncidenceHypothesis d N`;
2. the boundary oddness theorem for `GridIsSperner`.

The local parity and unit mesh fields are already discharged by
`grid_local_parity`/`grid_local_parity_for_certificate` and `grid_unit_mesh`.

After those two geometric facts are proved for arbitrarily fine `N`, use them
to prove `GridSpernerPackagesArbitrarilyFine d`.

Do not return to raw `BaryFreudenthalDatum` incidence; raw datum incidence
overcounts. The package layer counts geometric cells and geometric facets.
-/

/-
Boundary oddness plan:

For fixed `missing : Fin (d + 1)`, the boundary face
`x missing = 0` is naturally isomorphic to the barycentric grid
`SimplexGrid (d - 1) N` on the remaining coordinates.

The restriction of a Sperner labelling `L` to this face avoids colour `missing`
and becomes a Sperner labelling on the lower-dimensional face.

Boundary relevant facets for `missing` correspond to fully labelled
top-dimensional small simplices of the lower-dimensional grid.

Therefore `grid_boundary_odd` is proved by induction on `d`, using the
grid-Sperner theorem/package in dimension `d - 1`.
-/

theorem grid_sperner_for_brouwer_package {d N : ℕ}
    (P : GridSpernerForBrouwerPackage d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (hL : GridIsSperner L)
    (missing : Fin (d + 1)) :
    ∃ C : GridSmallSimplex d N,
      FullyLabelledGridSmallSimplex L C := by
  classical
  exact grid_sperner_for_brouwer_from_certificate
    P.T L missing hL
    (P.boundary_odd L missing hL)
    (P.local_parity L missing)

theorem grid_sperner_for_brouwer_package_with_mesh {d N : ℕ} [NeZero N]
    (P : GridSpernerForBrouwerPackage d N)
    (L : SimplexGrid d N → Fin (d + 1))
    (hL : GridIsSperner L)
    (missing : Fin (d + 1)) :
    ∃ C : GridSmallSimplex d N,
      FullyLabelledGridSmallSimplex L C ∧
        C.MeshLe ((1 : ℝ) / (N : ℝ)) := by
  classical
  rcases grid_sperner_for_brouwer_package P L hL missing with ⟨C, hC⟩
  refine ⟨C, hC, ?_⟩
  exact C.mesh_le_of_unitCoordinateMesh (P.unit_mesh C)

/-
The full `n`-dimensional Sperner theorem for the simplex grid is established through the
sorted-subset Freudenthal route in `Sperner/Kuhn/` (see `freudenthal_sperner`):
facet incidence, local parity, and boundary oddness are all proved there, unconditionally.
This module also provides the simplex-grid realisation and the geometric grid-cell model.
-/

/-- The Sperner boundary/support condition in barycentric coordinates. -/
def IsSperner {d N : ℕ} (C : Coloring d N) : Prop :=
  ∀ x : SimplexGrid d N, C.color x ∈ x.support

theorem color_positive_of_isSperner {d N : ℕ}
    {C : Coloring d N}
    (hC : IsSperner C)
    (x : SimplexGrid d N) :
    0 < x.1 (C.color x) := by
  classical
  have h := hC x
  simpa [SimplexGrid.support] using h

/-! ### Bounded base vectors (used by the cell parameterizations) -/

/-- Bases are bounded by `N` (since `(∑ b) + k = N`), so they live in a Fintype. -/
abbrev BoundedBaseVec (d N : ℕ) := Fin (d + 1) → Fin (N + 1)

def BoundedBaseVec.toNat {d N : ℕ} (b : BoundedBaseVec d N) : Fin (d + 1) → ℕ :=
  fun i => (b i).val

theorem BoundedBaseVec.toNat_le {d N : ℕ}
    (b : BoundedBaseVec d N) (i : Fin (d + 1)) :
    b.toNat i ≤ N :=
  Nat.le_of_lt_succ (b i).isLt


end BarycentricFreudenthal

